      function resolvePath(obj, path) {
        return path.split('.').reduce((acc, part) => (acc && acc[part] !== undefined ? acc[part] : undefined), obj);
      }

      function normalizeLang(input) {
        if (!input) return 'en';
        const lang = String(input).toLowerCase();
        if (lang.startsWith('es')) return 'es';
        if (lang.startsWith('pt')) return 'pt';
        if (lang.startsWith('en')) return 'en';
        return 'en';
      }

      function detectDeviceLang() {
        const fromNavigator = (navigator.languages && navigator.languages[0]) || navigator.language || 'en';
        return normalizeLang(fromNavigator);
      }

      function updateLangButtonUI(lang) {
        const meta = LANG_META[lang] || LANG_META.en;
        const langBtn = document.getElementById('iqxLangBtn');
        if (!langBtn) return;
        const btnFlag = langBtn.querySelector('img');
        const btnCode = langBtn.querySelector('span');
        if (btnFlag) btnFlag.src = meta.flag;
        if (btnCode) btnCode.textContent = meta.code;
      }

      function refreshLangLinks(activeLang) {
        document.querySelectorAll('a[href$=".html"]').forEach((link) => {
          try {
            const u = new URL(link.getAttribute('href'), window.location.href);
            u.searchParams.set('lang', activeLang);
            link.setAttribute('href', u.pathname + u.search);
          } catch (_) {}
        });
      }

      function applyLanguage(langInput) {
        const lang = normalizeLang(langInput);
        const dict = translations[lang] || translations.en;

        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          const value = resolvePath(dict, key);
          if (typeof value === 'string') {
            el.textContent = value;
            if (el.classList.contains('glitch-text')) el.setAttribute('data-text', value);
          }
        });

        document.querySelectorAll('[data-i18n-html]').forEach((el) => {
          const key = el.getAttribute('data-i18n-html');
          const value = resolvePath(dict, key);
          if (typeof value === 'string') el.innerHTML = value;
        });

        document.documentElement.lang = lang;
        localStorage.setItem(LANG_STORAGE_KEY, lang);
        updateLangButtonUI(lang);
        refreshLangLinks(lang);
      }

      const urlLangRaw = new URLSearchParams(window.location.search).get('lang');
      const urlLang = urlLangRaw ? normalizeLang(urlLangRaw) : null;
      const savedLang = localStorage.getItem(LANG_STORAGE_KEY);
      const initialLang = urlLang || (savedLang ? normalizeLang(savedLang) : detectDeviceLang());
      applyLanguage(initialLang);

      window.IQXI18N = {
        setLanguage: applyLanguage,
        getLanguage: () => normalizeLang(localStorage.getItem(LANG_STORAGE_KEY) || initialLang)
      };
    })();

    // Header menu + language dropdown
    (function initTopNavMenu() {
      const header = document.getElementById('iqxTopnav');
      const burger = document.getElementById('iqxBurger');
      const overlay = document.getElementById('iqxMenuOverlay');
      const backdrop = document.getElementById('iqxMenuBackdrop');
      const lang = document.getElementById('iqxLang');
      const langBtn = document.getElementById('iqxLangBtn');
      const langMenu = document.getElementById('iqxLangMenu');
      const langButtons = langMenu ? Array.from(langMenu.querySelectorAll('button')) : [];
      const navLinks = overlay ? Array.from(overlay.querySelectorAll('a')) : [];
      const contactBtn = document.getElementById('iqxHeaderContact');

      if (!header || !burger || !overlay || !backdrop) return;

      function closeMenu() {
        overlay.classList.remove('active');
        backdrop.classList.remove('active');
        header.classList.remove('menu-open');
        document.body.style.overflow = '';
      }

      function openMenu() {
        overlay.classList.add('active');
        backdrop.classList.add('active');
        header.classList.add('menu-open');
        if (window.innerWidth <= 980) document.body.style.overflow = 'hidden';
      }

      burger.addEventListener('click', function() {
        const isOpen = overlay.classList.contains('active');
        if (isOpen) closeMenu();
        else openMenu();
      });

      backdrop.addEventListener('click', closeMenu);
      navLinks.forEach((link) => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const href = link.getAttribute('href');
          if (!href) return;

          navLinks.forEach((item) => item.classList.remove('is-typing'));
          link.classList.add('is-typing');

          setTimeout(() => {
            window.location.href = href;
          }, 2000);
        });
      });

      if (lang && langBtn && langMenu) {
        langBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          const expanded = lang.classList.toggle('open');
          langBtn.setAttribute('aria-expanded', String(expanded));
        });

        langButtons.forEach((btn) => {
          btn.addEventListener('click', function() {
            const code = (btn.getAttribute('data-code') || 'EN').toLowerCase();
            if (window.IQXI18N && typeof window.IQXI18N.setLanguage === 'function') {
              window.IQXI18N.setLanguage(code);
            }
            lang.classList.remove('open');
            langBtn.setAttribute('aria-expanded', 'false');
          });
        });

        document.addEventListener('click', function(e) {
          if (!lang.contains(e.target)) {
            lang.classList.remove('open');
            langBtn.setAttribute('aria-expanded', 'false');
          }
        });
      }

      if (contactBtn) {
        contactBtn.addEventListener('click', function(e) {
          e.preventDefault();
          navigateWithCardSound('contacto.html');
        });
      }

      window.addEventListener('resize', function() {
        if (window.innerWidth > 980) document.body.style.overflow = '';
      });
    })();

    const cardClickSfx = (function createCardClickSound() {
      try {
        const audio = new Audio('./assets/sound/card.mp3');
        audio.preload = 'auto';
        audio.volume = 0.9;
        return audio;
      } catch (_) {
        return null;
      }
    })();

    function playCardClickSound() {
      if (!cardClickSfx) return;
      try {
        cardClickSfx.pause();
        cardClickSfx.currentTime = 0;
        const played = cardClickSfx.play();
        if (played && typeof played.catch === 'function') played.catch(() => {});
      } catch (_) {}
    }

    function navigateWithCardSound(url, delayMs = 600) {
      if (!url) return;
      playCardClickSound();
      setTimeout(function() {
        window.location.href = url;
      }, delayMs);
    }

    // Diagnosis button redirect
    (function initDiagnosisModal() {
      const startBtn = document.getElementById('startDiagnosisBtn');
      if (!startBtn) return;

      startBtn.addEventListener('click', function(e) {
        e.preventDefault();
        navigateWithCardSound('tests.html');
      });
    })();

    // Training button redirect
    (function initTrainingModal() {
      const startBtn = document.getElementById('startTrainingBtn');
      if (!startBtn) return;

      startBtn.addEventListener('click', function(e) {
        e.preventDefault();
        navigateWithCardSound('training.html');
      });
    })();

    // ---- Swiper Cards Section 6 ----
    (function initSwiperCards() {
      // Wait for Swiper to be loaded
      if (typeof Swiper === 'undefined') {
        setTimeout(initSwiperCards, 100);
        return;
      }
      const isMobileCards = window.matchMedia('(max-width: 768px)').matches;
      const isDesktopCards = window.matchMedia('(min-width: 981px)').matches;
      
      const iqxSwiper = new Swiper(".iqx-swiper", {
        effect: isDesktopCards ? "slide" : "cards",
        grabCursor: true,
        centeredSlides: true,
        slidesPerView: isDesktopCards ? 3 : 1,
        initialSlide: isDesktopCards ? 1 : 0,
        spaceBetween: isDesktopCards ? 24 : 0,
        cardsEffect: {
          perSlideOffset: isMobileCards ? 72 : 10,
          perSlideRotate: isMobileCards ? 0 : 2,
          slideShadows: false,
        },
        speed: 520,
        resistanceRatio: 0.75,
      });
    })();

    // Modern footer animations
    (function initModernFooter() {
      const leftCard = document.getElementById('mxfLeftCard');
      const rightCard = document.getElementById('mxfRightCard');
      const cube = document.getElementById('mxfCube');
      const canvas = document.getElementById('mxfCanvas');
      if (!leftCard || !rightCard || !cube || !canvas || typeof gsap === 'undefined') return;

      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.from(leftCard, { y: 70, opacity: 0, duration: 0.8 })
        .from(rightCard, { x: 40, opacity: 0, duration: 0.7 }, "-=0.5")
        .from(cube, { scale: 0, rotate: 120, opacity: 0, duration: 0.7, ease: "back.out(1.7)" }, "-=0.35");

      if (window.THREE) {
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, 1, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
        const resize = () => {
          const rect = leftCard.getBoundingClientRect();
          renderer.setSize(rect.width, rect.height, false);
          camera.aspect = rect.width / rect.height;
          camera.updateProjectionMatrix();
        };
        resize();
        window.addEventListener('resize', resize);
        const particlesGeometry = new THREE.BufferGeometry();
        const count = 50;
        const arr = new Float32Array(count * 3);
        for (let i = 0; i < count * 3; i++) arr[i] = (Math.random() - 0.5) * 5;
        particlesGeometry.setAttribute('position', new THREE.BufferAttribute(arr, 3));
        const particles = new THREE.Points(
          particlesGeometry,
          new THREE.PointsMaterial({ size: 0.02, color: 0xffffff, transparent: true, opacity: 0.62 })
        );
        scene.add(particles);
        camera.position.z = 3;
        const animate = () => {
          particles.rotation.x += 0.001;
          particles.rotation.y += 0.0013;
          renderer.render(scene, camera);
          requestAnimationFrame(animate);
        };
        animate();
      }
    })();

    // WhatsApp CTA
    (function initWhatsAppButton() {
      const btn = document.getElementById('whatsappBtn');
      if (!btn) return;

      btn.addEventListener('click', function () {
        window.location.href = 'https://api.whatsapp.com/send/?phone=59173600060&text=Bienvenido+a+IQExponencial+en+que+podemos+ayudarle&type=phone_number&app_absent=0';
      });
    })();

    // Email CTA
    (function initEmailButton() {
      const btn = document.getElementById('emailBtn');
      if (!btn) return;

      btn.addEventListener('click', function () {
        window.location.href = 'mailto:contacto@iqexponencial.com';
      });
    })();

    // Method CTA
    (function initMethodCtaButton() {
      const btn = document.getElementById('methodCtaBtn');
      if (!btn) return;

      btn.addEventListener('click', function (e) {
        e.preventDefault();
        navigateWithCardSound('metodox.html');
      });
    })();

    // Add click sound + delay for local HTML links (except menu links with typing effect)
    (function initLinkSoundNavigation() {
      document.addEventListener('click', function (e) {
        const link = e.target.closest('a[href]');
        if (!link) return;

        if (link.closest('.iqx-menu-list') || link.closest('.iqx-topnav-links')) return;

        const href = (link.getAttribute('href') || '').trim();
        if (!href) return;
        if (href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('javascript:')) return;
        if (!/\.html($|[?#])/.test(href)) return;

        e.preventDefault();
        navigateWithCardSound(href);
      });
    })();

    function runAfterPreloader(callback) {
      if (window.__iqxPreloaderDone || !document.body.classList.contains('preloader-active')) {
        callback();
        return;
      }
      window.addEventListener('iqx:preloader-done', callback, { once: true });
    }

    (function initSegmentsTitleReveal() {
      const titleWrap = document.getElementById('segmentsTitleWrap');
      if (!titleWrap) return;

      runAfterPreloader(() => {
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                titleWrap.classList.add('is-visible');
                observer.disconnect();
              }
            });
          }, { threshold: 0.35 });
          observer.observe(titleWrap);
        } else {
          titleWrap.classList.add('is-visible');
        }
      });
    })();

    (function initHeroBrainReveal() {
      const section = document.querySelector('.hero.hero-brain');
      if (!section) return;

      runAfterPreloader(() => {
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                section.classList.add('is-visible');
                observer.disconnect();
              }
            });
          }, { threshold: 0.25 });
          observer.observe(section);
        } else {
          section.classList.add('is-visible');
        }
      });
    })();

    (function initHeroTitleReveal() {
      const heroes = Array.from(document.querySelectorAll('.hero'));
      if (!heroes.length) return;

      runAfterPreloader(() => {
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('title-visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.25 });

          heroes.forEach((hero) => observer.observe(hero));
        } else {
          heroes.forEach((hero) => hero.classList.add('title-visible'));
        }
      });
    })();

  </script>

  <script>
    (function lazyLoadChatWidget() {
      let loaded = false;
      let preloaderDone = !!window.__iqxPreloaderDone;

      function loadWidget() {
        if (loaded || !preloaderDone) return;
        loaded = true;

        const script = document.createElement('script');
        script.src = 'https://iqexponencial.app/iqex-chat-widget.js';
        script.setAttribute('data-base-url', 'https://iqexponencial.app');
        script.setAttribute('data-site', 'miweb-estatica');
        script.setAttribute('data-title', 'Asesor Personal');
        script.setAttribute('data-position', 'right');
        document.body.appendChild(script);
      }

      if (!preloaderDone) {
        window.addEventListener('iqx:preloader-done', function () {
          preloaderDone = true;
          loadWidget();
        }, { once: true });
      }

      loadWidget();
    })();
  </script>
  <script src="scripts.js?v=20260227-1"></script>
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script>
    (function initPagePreloader() {
      window.__iqxPreloaderDone = false;
      const preloader = document.getElementById('iqxPreloader');
      const wordEl = document.getElementById('iqxPreloaderWord');
      const percentEl = document.getElementById('iqxPreloaderPercent');
      if (!preloader || !wordEl || !percentEl) {
        window.__iqxPreloaderDone = true;
        window.dispatchEvent(new Event('iqx:preloader-done'));
        return;
      }

      document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
        img.loading = 'eager';
      });

      const word = 'eXponencial';
      wordEl.innerHTML = '';
      word.split('').forEach((char, index) => {
        const span = document.createElement('span');
        span.className = 'letter';
        span.textContent = char;
        if (char.toLowerCase() === 'x') span.classList.add('x');
        if (char.toLowerCase() === 'o') span.classList.add('o');
        wordEl.appendChild(span);
        setTimeout(() => {
          span.style.opacity = '1';
          span.style.transform = 'translateY(0)';
        }, 120 + (index * 90));
      });

      let progress = 0;
      let target = 12;
      let loaded = false;
      const startAt = performance.now();

      function estimateTarget() {
        const images = Array.from(document.images || []);
        const total = images.length || 1;
        const done = images.filter((img) => img.complete).length;
        const imageRatio = Math.min(done / total, 1);
        const elapsed = (performance.now() - startAt) / 1000;
        const timeRatio = Math.min(elapsed / 4, 1);
        const combined = Math.max(imageRatio * 0.85, timeRatio * 0.92);
        target = Math.max(target, Math.floor(combined * 100));
        if (!loaded) target = Math.min(target, 96);
      }

      function hidePreloader() {
        preloader.classList.add('is-hidden');
        document.body.classList.remove('preloader-active');
        window.__iqxPreloaderDone = true;
        window.dispatchEvent(new Event('iqx:preloader-done'));
        setTimeout(() => {
          if (preloader && preloader.parentNode) preloader.parentNode.removeChild(preloader);
        }, 550);
      }

      function tick() {
        estimateTarget();
        progress += (target - progress) * 0.12;
        if (target - progress < 0.35) progress = target;
        const shown = Math.max(0, Math.min(100, Math.round(progress)));
        percentEl.textContent = shown + '%';

        if (loaded && shown >= 100) {
          hidePreloader();
          return;
        }
        requestAnimationFrame(tick);
      }

      window.addEventListener('load', () => {
        loaded = true;
        target = 100;
      }, { once: true });

      requestAnimationFrame(tick);
    })();
  </script>
  <script>
    (function initVisibilityPowerSaver() {
      const PAUSE_AFTER_MS = 10000;
      const PAUSED_CLASS = "app-paused";
      let hideTimer = null;
      let paused = false;

      function setPaused(next) {
        if (paused === next) return;
        paused = next;
        document.documentElement.classList.toggle(PAUSED_CLASS, paused);
        if (document.body) document.body.classList.toggle(PAUSED_CLASS, paused);

        if (window.gsap && window.gsap.globalTimeline) {
          if (paused) window.gsap.globalTimeline.pause();
          else window.gsap.globalTimeline.resume();
        }

        document.querySelectorAll("video, audio").forEach((m) => {
          if (paused) {
            if (!m.paused) {
              m.dataset.wasPlaying = "1";
              m.pause();
            }
          } else if (m.dataset.wasPlaying === "1") {
            m.play().catch(() => {});
            delete m.dataset.wasPlaying;
          }
        });

        window.dispatchEvent(new CustomEvent(paused ? "app:pause" : "app:resume"));
      }

      function schedulePause() {
        clearTimeout(hideTimer);
        hideTimer = setTimeout(() => setPaused(true), PAUSE_AFTER_MS);
      }

      function resumeNow() {
        clearTimeout(hideTimer);
        setPaused(false);
      }

      function onVisibilityChange() {
        if (document.hidden) schedulePause();
        else resumeNow();
      }

      document.addEventListener("visibilitychange", onVisibilityChange, { passive: true });
      window.addEventListener("pagehide", schedulePause, { passive: true });
      window.addEventListener("pageshow", resumeNow, { passive: true });
      window.addEventListener("blur", () => { if (!document.hidden) schedulePause(); }, { passive: true });
      window.addEventListener("focus", resumeNow, { passive: true });
      onVisibilityChange();
    })();
  </script>
  <style>
    .app-paused *,
    .app-paused *::before,
    .app-paused *::after {
      animation-play-state: paused !important;
    }
  </style>
</body>

</html>



