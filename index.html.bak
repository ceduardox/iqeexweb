  <style>
    .mxf-wrap{position:relative;width:min(1220px,calc(100% - 32px));margin:40px auto 50px}
    .mxf-grid{display:grid;grid-template-columns:1fr;gap:16px}
    @media (min-width:1024px){.mxf-grid{grid-template-columns:360px 1fr}}
    .mxf-card-left{background:linear-gradient(135deg,#86efac 0%,#bef264 100%);border-radius:28px;padding:28px;position:relative;overflow:hidden;min-height:290px;display:flex;flex-direction:column;justify-content:space-between;cursor:pointer;animation:mxfLeftFloat 5.2s ease-in-out infinite}
    .mxf-card-left::before{content:"";position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(255,255,255,.35) 0%,transparent 68%);animation:mxfShimmer 8s linear infinite}
    .mxf-card-left::after{content:"";position:absolute;left:50%;top:50%;width:86px;height:86px;transform:translate(-50%,-50%);border-radius:999px;border:2px solid rgba(255,255,255,.35);box-shadow:0 0 0 0 rgba(255,255,255,.25);animation:mxfRadar 2.6s ease-out infinite;pointer-events:none}
    .mxf-logo{display:flex;align-items:center;gap:10px;z-index:2;position:relative}
    .mxf-logo img{width:34px;height:34px;object-fit:contain}
    .mxf-logo span{font-family:'Gilroy-Bold',sans-serif;font-size:26px;color:#0b0f17}
    .mxf-tagline{z-index:2;position:relative}
    .mxf-tagline p{margin:0;color:#0b0f17}
    .mxf-tagline .l1{font-weight:700;font-size:20px;line-height:1.2}
    .mxf-tagline .l2{opacity:.72;font-size:20px}
    .mxf-canvas{position:absolute;inset:0;pointer-events:none;opacity:.55}
    .mxf-card-right{position:relative;background:rgba(255,255,255,.72);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.35);border-radius:28px;padding:28px;overflow:hidden}
    .mxf-cube{position:absolute;top:18px;right:18px;width:96px;height:96px;border-radius:20px;background:linear-gradient(135deg,#d9f99d 0%,#bef264 100%);box-shadow:0 16px 40px rgba(0,0,0,.14);display:flex;align-items:center;justify-content:center;animation:mxfFloat 6s ease-in-out infinite}
    .mxf-cube img{width:44px;height:44px}
    .mxf-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:38px}
    .mxf-title{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#8f96a8;margin:0 0 10px}
    .mxf-links{list-style:none;margin:0;padding:0}
    .mxf-links li{margin:0 0 8px}
    .mxf-links a{font-size:22px;line-height:1.18;color:#10131d;text-decoration:none;position:relative;display:inline-block}
    .mxf-links a::after{content:"";position:absolute;left:0;bottom:-2px;width:0;height:2px;background:#000;transition:width .26s ease}
    .mxf-links a:hover::after{width:100%}
    .mxf-bottom{padding-top:16px;border-top:1px solid rgba(15,20,36,.12);display:flex;align-items:center;justify-content:flex-start}
    .mxf-copy{margin:0;color:#8b92a4;font-size:13px}
    .mxf-watermark{position:absolute;left:50%;bottom:-7vw;transform:translateX(-50%);font-family:'Gilroy-Bold',sans-serif;font-size:20vw;color:transparent;line-height:1;pointer-events:none;user-select:none;white-space:nowrap}
    .mxf-watermark::before{content:attr(data-text);position:absolute;left:0;top:0;color:rgba(0,0,0,.035);white-space:nowrap;clip-path:inset(0 100% 0 0);animation:mxfTypeLoop 6.2s steps(13,end) infinite}
    @keyframes mxfShimmer{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
    @keyframes mxfFloat{0%,100%{transform:translateY(0) rotateX(0) rotateY(0)}50%{transform:translateY(-18px) rotateX(10deg) rotateY(10deg)}}
    @keyframes mxfLeftFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
    @keyframes mxfRadar{0%{opacity:.9;transform:translate(-50%,-50%) scale(.72)}100%{opacity:0;transform:translate(-50%,-50%) scale(2.25)}}
    @keyframes mxfTypeLoop{
      0%{clip-path:inset(0 100% 0 0)}
      45%{clip-path:inset(0 0 0 0)}
      55%{clip-path:inset(0 0 0 0)}
      100%{clip-path:inset(0 100% 0 0)}
    }
  </style>
