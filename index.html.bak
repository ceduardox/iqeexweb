  <!-- Favicon -->
  <link rel="icon" type="image/png" href="./assets/images/favicon.png" />
  
  <link href="https://fonts.cdnfonts.com/css/gilroy-bold" rel="stylesheet">
  <link rel="stylesheet" href="styles.css?v=20260227-1">
  <link rel="stylesheet" href="sec6-styles.css?v=20260227-1">
  <link rel="stylesheet" href="sec7-styles.css?v=20260227-1">
  <!-- Swiper CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
  <!-- Ionicons for modern icons -->

  <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
  <!-- GSAP + ScrollTrigger -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" referrerpolicy="no-referrer"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" referrerpolicy="no-referrer"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" referrerpolicy="no-referrer"></script>
  <style>
    .iqx-topnav{
      --iqx-nav-accent:#78a8ff;
      --iqx-nav-btn:#7de3e3;
      position:fixed;
      top:0;
      left:0;
      width:100%;
      z-index:4000;
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:22px 5%;
      transition:all .45s cubic-bezier(.22,1,.36,1);
    }
    .iqx-topnav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:#fff;z-index:4002}
    .iqx-topnav-logo img{height:44px;width:auto;display:block}
    .iqx-topnav-logo span{font-family:'Gilroy-Bold',sans-serif;font-size:21px;letter-spacing:.2px}
    .iqx-topnav-glass{
      display:flex;
      align-items:center;
      gap:16px;
      background:linear-gradient(135deg, rgba(22, 31, 66, 0.28), rgba(70, 30, 120, 0.22));
      border:1px solid rgba(255,255,255,.2);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      border-radius:999px;
      padding:8px 10px 8px 18px;
      transition:all .5s cubic-bezier(.22,1,.36,1);
    }
    .iqx-topnav-links{
      display:none;
      gap:22px;
      opacity:0;
      transform:translateX(8px);
      pointer-events:none;
      transition:opacity .22s ease,transform .22s ease;
    }
    @media (min-width:981px){
      .iqx-topnav.menu-open .iqx-topnav-links{
        display:flex;
        opacity:1;
        transform:translateX(0);
        pointer-events:auto;
      }
    }
    .iqx-topnav-links a{
      color:#fff;
      text-decoration:none;
      font-size:15px;
      opacity:1;
      transition:color .14s ease,transform .14s ease,text-shadow .14s ease;
    }
    .iqx-topnav-links a:hover{
      color:#00ffd5;
      transform:translateY(-1px);
      text-shadow:0 0 12px rgba(0,255,213,.35);
    }
    .iqx-topnav-lang{position:relative}
    .iqx-topnav-lang-btn{
      border:none;
      background:rgba(255,255,255,.12);
      color:#fff;
      border:1px solid rgba(255,255,255,.2);
      border-radius:999px;
      padding:9px 12px;
      display:flex;
      align-items:center;
      gap:6px;
      cursor:pointer;
      font-size:13px;
      transition:all .25s;
    }
    .iqx-topnav-lang-btn:hover{background:rgba(255,255,255,.18)}
    .iqx-topnav-lang-btn img{width:16px;height:12px;border-radius:2px;object-fit:cover}
    .iqx-topnav-lang-menu{
      position:absolute;
      right:0;
      top:calc(100% + 8px);
      min-width:145px;
      background:#fff;
      border-radius:12px;
      box-shadow:0 12px 30px rgba(10,20,38,.22);
      overflow:hidden;
      opacity:0;
      transform:translateY(-8px);
      pointer-events:none;
      transition:all .24s ease;
    }
    .iqx-topnav-lang.open .iqx-topnav-lang-menu{opacity:1;transform:translateY(0);pointer-events:auto}
    .iqx-topnav-lang-menu button{
      width:100%;
      border:none;
      background:#fff;
      display:flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      font-size:13px;
      color:#182037;
      cursor:pointer;
      text-align:left;
    }
    .iqx-topnav-lang-menu button:hover{background:#f2f5fb}
    .iqx-topnav-lang-menu img{width:16px;height:12px;border-radius:2px;object-fit:cover}
    .iqx-topnav-contact{
      border:none;
      background:var(--iqx-nav-btn);
      color:#032d46;
      padding:12px 18px;
      border-radius:12px;
      font-size:13px;
      font-family:'Gilroy-Bold',sans-serif;
      cursor:pointer;
      transition:transform .2s,box-shadow .2s;
    }
    .iqx-topnav-contact:hover{transform:translateY(-1px);box-shadow:0 8px 16px rgba(125,227,227,.28)}
    .iqx-topnav-burger{
      width:34px;height:20px;border:none;background:transparent;display:flex;flex-direction:column;justify-content:space-between;cursor:pointer;padding:0;
    }
    .iqx-topnav-burger span{height:2px;width:100%;background:#fff;transition:all .45s cubic-bezier(.22,1,.36,1)}
    .iqx-topnav.menu-open .iqx-topnav-burger span:nth-child(1){transform:translateY(8px) rotate(45deg)}
    .iqx-topnav.menu-open .iqx-topnav-burger span:nth-child(2){opacity:0}
    .iqx-topnav.menu-open .iqx-topnav-burger span:nth-child(3){transform:translateY(-8px) rotate(-45deg)}
    .iqx-menu-backdrop{
      position:fixed;inset:0;background:rgba(0,10,24,.28);backdrop-filter:blur(1px);-webkit-backdrop-filter:blur(1px);z-index:3900;opacity:0;pointer-events:none;transition:opacity .35s ease;
    }
    .iqx-menu-backdrop.active{opacity:1;pointer-events:auto}
    .iqx-menu-overlay{
      position:fixed;
      top:0;
      right:0;
      height:100%;
      width:min(420px,92vw);
      background:#fff;
      z-index:3950;
      transform:translateX(102%);
      transition:transform .52s cubic-bezier(.22,1,.36,1);
      box-shadow:-18px 0 44px rgba(0,0,0,.18);
      display:flex;
      align-items:flex-start;
      padding-top:86px;
    }
    .iqx-menu-overlay.active{transform:translateX(0)}
    .iqx-menu-list{list-style:none;padding:0 34px;width:100%}
    .iqx-menu-list li{margin:16px 0;overflow:hidden}
    .iqx-menu-list a{
      text-decoration:none;
      color:#cfd5e6;
      font-family:'Gilroy-Bold',sans-serif;
      font-size:44px;
      line-height:.95;
      display:inline-block;
      transform:translateY(100%);
      transition:transform .28s cubic-bezier(.22,1,.36,1),color .14s ease,padding-left .14s ease,text-shadow .14s ease;
    }
    .iqx-menu-list a.is-typing{
      color:#00ffd5;
      text-shadow:0 0 16px rgba(0,255,213,.45);
      pointer-events:none;
      animation:iqxLinkFlash 400ms linear 5;
    }
    .iqx-menu-overlay.active .iqx-menu-list a{
      transform:translateY(0);
      animation:iqxMenuDrift 3.8s ease-in-out infinite;
    }
    .iqx-menu-overlay.active .iqx-menu-list a.is-typing{
      animation:iqxLinkFlash 400ms linear 5 !important;
    }
    .iqx-menu-list a:hover{color:#00ffd5;padding-left:12px;text-shadow:0 0 14px rgba(0,255,213,.35)}
    .iqx-menu-list li:nth-child(1) a{transition-delay:.02s}
    .iqx-menu-list li:nth-child(2) a{transition-delay:.04s}
    .iqx-menu-list li:nth-child(3) a{transition-delay:.06s}
    .iqx-menu-list li:nth-child(4) a{transition-delay:.08s}
    .iqx-menu-list li:nth-child(5) a{transition-delay:.10s}
    .iqx-menu-list li:nth-child(6) a{transition-delay:.12s}
    .iqx-menu-list li:nth-child(1) a{animation-delay:.05s}
    .iqx-menu-list li:nth-child(2) a{animation-delay:.12s}
    .iqx-menu-list li:nth-child(3) a{animation-delay:.19s}
    .iqx-menu-list li:nth-child(4) a{animation-delay:.26s}
    .iqx-menu-list li:nth-child(5) a{animation-delay:.33s}
    .iqx-menu-list li:nth-child(6) a{animation-delay:.40s}
    @keyframes iqxMenuDrift{
      0%,100%{transform:translateY(0)}
      50%{transform:translateY(-2px)}
    }
    @keyframes iqxLinkFlash{
      0%,100%{
        opacity:1;
        color:#00ffd5;
        transform:scale(1);
      }
      50%{
        opacity:.28;
        color:#ffffff;
        transform:scale(1.08);
      }
    }
    .container > .hero{margin-top:0}
    .cards-row{display:none !important}
    .lower{display:none !important}
    @media (max-width:980px){
      .iqx-topnav-contact{display:none}
    }
    @media (max-width:700px){
      .iqx-topnav{padding:14px 4%}
      .iqx-topnav-logo img{height:38px}
      .iqx-topnav-logo span{font-size:17px}
      .iqx-menu-list a{font-size:16vw}
      .container > .hero{margin-top:0}
    }
    .hero.hero-brain{
      position:relative;
      overflow:hidden;
      min-height:520px;
      width:100%;
      box-sizing:border-box;
      background-image:url('./assets/images/pc.jpeg');
      background-size:cover;
      background-position:center;
      background-repeat:no-repeat;
      opacity:0;
      transform:translateX(-520px);
      transition:opacity .9s ease, transform 1.05s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hero.hero-brain.is-visible{
      opacity:1;
      transform:translateX(0);
    }
    .hero.hero-brain .hero-brain-layer{
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      object-fit:cover;
      z-index:1;
      pointer-events:none;
      opacity:0;
      transform:translateY(-560px);
      transition:opacity .85s ease .12s, transform 1s cubic-bezier(0.22, 1, 0.36, 1) .12s;
      will-change:opacity, transform;
      animation:heroBrainColorLoop 8s ease-in-out infinite;
    }
    @media (min-width:701px){
      .hero.hero-brain .hero-brain-layer{
        inset:auto auto 0 0;
        width:min(1100px, 92vw);
        height:auto;
        max-height:100%;
        object-fit:contain;
        object-position:left bottom;
        transform:translate3d(0, -560px, 0);
      }
      .hero.hero-brain.is-visible .hero-brain-layer{
        transform:translate3d(0, 0, 0);
      }
    }
    .hero.hero-brain.is-visible .hero-brain-layer{
      opacity:1;
      transform:translateY(0);
    }
    .hero.hero-brain .hero-text,
    .hero.hero-brain .mesh{
      position:relative;
      z-index:2;
    }
    .hero.hero-brain .title .accent{
      color:transparent;
      background-image:linear-gradient(90deg, #8b6bf8 0%, #22d3ee 50%, #3b82f6 100%);
      background-size:220% 220%;
      -webkit-background-clip:text;
      background-clip:text;
      animation:heroBrainAccentGradient 4s linear infinite;
    }
    @media (min-width:701px){
      .hero.hero-brain{
        min-height:clamp(520px, 84vh, 760px);
        padding:clamp(86px, 12vh, 128px) clamp(34px, 5.4vw, 92px) clamp(56px, 8vh, 84px);
        display:flex;
        align-items:center;
        justify-content:center;
        gap:0;
      }
      .hero.hero-brain .hero-text{
        width:min(920px, 86vw);
        margin:0 auto;
        text-align:center;
        display:flex;
        flex-direction:column;
        align-items:center;
        justify-content:center;
      }
      .hero.hero-brain .subtitle,
      .hero.hero-brain .lead{
        max-width:760px;
        margin-left:auto;
        margin-right:auto;
      }
      .hero.hero-brain .mesh{
        position:absolute;
        right:clamp(18px, 4vw, 60px);
        bottom:clamp(14px, 5vh, 44px);
        width:min(300px, 24vw);
        height:auto;
        opacity:.62;
        pointer-events:none;
      }
    }
    @keyframes heroBrainAccentGradient{
      0%{ background-position:0% 50%; }
      50%{ background-position:100% 50%; }
      100%{ background-position:0% 50%; }
    }
    @keyframes heroBrainColorLoop{
      0%{
        filter:hue-rotate(0deg) saturate(1.18) brightness(1.02) contrast(1.04);
      }
      33%{
        filter:hue-rotate(34deg) saturate(1.42) brightness(1.08) contrast(1.1);
      }
      66%{
        filter:hue-rotate(-30deg) saturate(1.34) brightness(1.06) contrast(1.08);
      }
      82%{
        filter:hue-rotate(0deg) saturate(0.05) brightness(1.45) contrast(1.12);
      }
      100%{
        filter:hue-rotate(0deg) saturate(1.18) brightness(1.02) contrast(1.04);
      }
    }
    .hero .title{
      opacity:0;
      transform:translateX(-480px);
      transition:opacity .85s ease, transform 1s cubic-bezier(0.22, 1, 0.36, 1);
      will-change:opacity, transform;
    }
    .hero.title-visible .title{
      opacity:1;
      transform:translateX(0);
    }
    .hero .subtitle,
    .hero .lead{
      opacity:0;
      transform:translateY(180px);
      transition:opacity .8s ease, transform .95s cubic-bezier(0.22, 1, 0.36, 1);
      will-change:opacity, transform;
    }
    .hero.hero-brain .lead{
      color:#29376c;
    }
    .hero.title-visible .subtitle,
    .hero.title-visible .lead{
      opacity:1;
      transform:translateY(0);
    }
    .hero.title-visible .subtitle{ transition-delay:.16s; }
    .hero.title-visible .lead{ transition-delay:.28s; }
    @media (max-width:700px){
      .hero.hero-brain{
        min-height:unset;
        background-image:url('./assets/images/movile.jpg') !important;
        background-size:96% auto !important;
        background-repeat:no-repeat;
        background-position:center 78px;
        transform:translateX(-120px);
      }
      .hero.hero-brain .hero-brain-layer{
        transform:translateY(-140px);
      }
      .hero.hero-brain .hero-text{
        margin-top:17rem;
        margin-bottom:7rem;
      }
      .hero .title{
        font-size:38px;
        transform:translateX(-140px);
      }
      .hero .subtitle,
      .hero .lead{
        transform:translateY(56px);
      }
    }
    body.preloader-active { overflow: hidden; }
    .iqx-preloader{
      position:fixed;
      inset:0;
      z-index:99999;
      background:radial-gradient(circle at 20% 20%, #1a2040 0%, #0b0f22 45%, #05070f 100%);
      display:flex;
      align-items:center;
      justify-content:center;
      transition:opacity .5s ease,visibility .5s ease;
    }
    .iqx-preloader.is-hidden{
      opacity:0;
      visibility:hidden;
      pointer-events:none;
    }
    .iqx-preloader-content{
      text-align:center;
      width:min(92vw,920px);
      padding:20px;
    }
    .iqx-preloader-title{
      margin:0;
      font-size:clamp(42px, 10vw, 108px);
      line-height:1;
      font-weight:900;
      letter-spacing:.5px;
      text-shadow:0 8px 24px rgba(0,0,0,.45);
    }
    .iqx-preloader-title .letter{
      display:inline-block;
      color:#fff;
      opacity:0;
      transform:translateY(30px);
      transition:all .5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .iqx-preloader-title .letter.x{
      color:#c77dff;
      animation:iqxPreSpinX 3s ease-in-out infinite;
    }
    .iqx-preloader-title .letter.o{
      color:#ffd700;
      animation:iqxPrePulseO 2s ease-in-out infinite;
    }
    .iqx-preloader-progress{
      margin-top:14px;
      font-family:'Gilroy-Bold',sans-serif;
      font-size:clamp(16px, 2.8vw, 24px);
      color:rgba(255,255,255,.92);
      letter-spacing:2px;
    }
    @keyframes iqxPreSpinX{
      0%,100%{transform:rotate(0deg)}
      50%{transform:rotate(360deg)}
    }
    @keyframes iqxPrePulseO{
      0%,100%{transform:scale(1)}
      50%{transform:scale(1.2)}
    }
    .iqx-segments-title-wrap{
      background:#fff;
      border-top:5px solid #7a2bc2;
      padding:34px 20px 30px;
      text-align:center;
      overflow:hidden;
    }
    .iqx-segments-title{
      margin:0;
      font-size:clamp(38px,4.6vw,66px);
      line-height:1.12;
      font-weight:400;
      color:#121212;
    }
    .iqx-segments-title-word{
      display:inline-block;
      opacity:0;
      filter:blur(8px);
      will-change:transform,opacity,filter;
    }
    .iqx-segments-title-word.from-left{transform:translateX(-120px) rotate(-8deg)}
    .iqx-segments-title-word.from-right{transform:translateX(120px) rotate(8deg)}
    .iqx-segments-title-word.from-top{transform:translateY(-95px) scale(.85)}
    .iqx-segments-title-word.from-bottom{transform:translateY(95px) scale(1.1)}
    .iqx-segments-title-word.from-zoom{transform:scale(.2) rotate(-16deg)}
    .iqx-segments-title-wrap.is-visible .iqx-segments-title-word{
      animation:iqxSegmentsWordIn .9s cubic-bezier(.22,1,.36,1) forwards;
      animation-delay:var(--d,0ms);
    }
    @keyframes iqxSegmentsWordIn{
      0%{
        opacity:0;
        filter:blur(8px);
      }
      100%{
        transform:translateX(0) translateY(0) scale(1) rotate(0deg);
        opacity:1;
        filter:blur(0);
      }
    }
  </style>
</head>
<body class="preloader-active">
  <div class="iqx-preloader" id="iqxPreloader" aria-live="polite" aria-label="Cargando sitio">
    <div class="iqx-preloader-content">
      <h1 class="iqx-preloader-title" id="iqxPreloaderWord"></h1>
      <div class="iqx-preloader-progress" id="iqxPreloaderPercent">0%</div>
    </div>
  </div>
  <header class="iqx-topnav" id="iqxTopnav">
    <a href="#inicio" class="iqx-topnav-logo">
      <img src="./assets/images/logopro.png" alt="IQeXponencial logo"/>
      <span></span>
    </a>

    <div class="iqx-topnav-glass">
      <nav class="iqx-topnav-links" aria-label="Navegacion principal">
        <a href="index.html" data-i18n="header.home">Inicio</a>
        <a href="metodox.html" data-i18n="header.method">Metodo X</a>
        <a href="training.html" data-i18n="header.training">Entrenar</a>
        <a href="tests.html" data-i18n="header.test">Test</a>
        <a href="blog.html" data-i18n="header.blog">Blog</a>
        <a href="contacto.html" data-i18n="header.contact">Contacto</a>
      </nav>

      <div class="iqx-topnav-lang" id="iqxLang">
        <button class="iqx-topnav-lang-btn" id="iqxLangBtn" type="button" aria-expanded="false">
          <img src="https://flagcdn.com/w20/es.png" alt="Bandera de Espana"/>
          <span>ES</span>
          <ion-icon name="chevron-down-outline"></ion-icon>
        </button>
        <div class="iqx-topnav-lang-menu" id="iqxLangMenu">
          <button type="button" data-code="ES" data-flag="https://flagcdn.com/w20/es.png"><img src="https://flagcdn.com/w20/es.png" alt="Bandera de Espana"/> Espanol</button>
          <button type="button" data-code="EN" data-flag="https://flagcdn.com/w20/us.png"><img src="https://flagcdn.com/w20/us.png" alt="USA flag"/> English</button>
