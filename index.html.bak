    <div class="iqx-segments-title-wrap" id="segmentsTitleWrap">
      <h2 class="iqx-segments-title">
        <span class="iqx-segments-title-word from-left" style="--d:0ms;">¿Qué</span>
        <span class="iqx-segments-title-word from-top" style="--d:120ms;">está</span>
        <strong class="iqx-segments-title-word from-right" style="--d:240ms;font-weight:800;">frenando</strong>
        <span class="iqx-segments-title-word from-bottom" style="--d:360ms;">tu</span><br>
        <span class="iqx-segments-title-word from-zoom" style="--d:480ms;">potencial</span>
        <span class="iqx-segments-title-word from-left" style="--d:600ms;">hoy?</span>
