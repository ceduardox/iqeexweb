    <section class="segments" aria-labelledby="segments-title">
      <div class="segments-inner">
        <div class="segments-top"></div>
        <div class="segments-carousel">
          <button class="segments-arrow prev" aria-label="Anterior">‹</button>
          <div class="segments-track">
            <article class="segment">
              <div class="badge"><img src="./assets/images/boy2.png" alt="badge" loading="lazy" decoding="async"/></div>
              <div class="photo"><img src="./assets/images/boy.jpg" alt="Niños" loading="lazy" decoding="async"/></div>
              <div class="seg-text">
                <div class="seg-icon"><ion-icon name="happy"></ion-icon></div>
                <h4><span class="seg-age" data-i18n="segments.1.age">6-12 años</span> <span data-i18n="segments.1.title">Tareas eternas y falta de atención</span></h4><p data-i18n="segments.1.desc">Es inteligente pero se distrae fácilmente. Las tardes de estudio son una batalla de frustración.</p>
              </div>
            </article>
            <article class="segment">
              <div class="badge"><img src="./assets/images/jovenes.png" alt="badge" loading="lazy" decoding="async"/></div>
              <div class="photo"><img src="./assets/images/joven.jpg" alt="Adolescentes" loading="lazy" decoding="async"/></div>
              <div class="seg-text">
                <div class="seg-icon"><ion-icon name="school"></ion-icon></div>
                <h4><span class="seg-age" data-i18n="segments.2.age">13-17 años</span> <span data-i18n="segments.2.title">Desmotivación académica</span></h4><p data-i18n="segments.2.desc">Estudia sin técnica. Lee pero no retiene. Siente que el colegio es lento y aburrido.</p>
              </div>
            </article>
            <article class="segment">
              <div class="badge"><img src="./assets/images/uni.png" alt="badge" loading="lazy" decoding="async"/></div>
              <div class="photo"><img src="./assets/images/universitario.jpg" alt="Universitarios" loading="lazy" decoding="async"/></div>
              <div class="seg-text">
                <div class="seg-icon"><ion-icon name="library"></ion-icon></div>
                <h4><span class="seg-age" data-i18n="segments.3.age">Universidad</span> <span data-i18n="segments.3.title">Sobrecarga y ansiedad</span></h4><p data-i18n="segments.3.desc">Lecturas interminables para tesis y bloqueos mentales (mente en blanco) durante los exámenes por estrés.</p>
              </div>
            </article>
            <article class="segment">
              <div class="badge"><img src="./assets/images/2.png" alt="badge" loading="lazy" decoding="async"/></div>
              <div class="photo"><img src="./assets/images/profesional.jpg" alt="Profesionales" loading="lazy" decoding="async"/></div>
              <div class="seg-text">
                <div class="seg-icon"><ion-icon name="briefcase"></ion-icon></div>
                <h4><span class="seg-age" data-i18n="segments.4.age">Profesional</span> <span data-i18n="segments.4.title">Fatiga mental y estancamiento</span></h4><p data-i18n="segments.4.desc">Niebla mental (Brain Fog). Te cuesta mantener el enfoque profundo y expresar ideas con autoridad en reuniones.</p>
              </div>
            </article>
            <article class="segment">
              <div class="badge"><img src="./assets/images/adulto.png" alt="badge" loading="lazy" decoding="async"/></div>
              <div class="photo"><img src="./assets/images/adulto.jpg" alt="Adulto Mayor" loading="lazy" decoding="async"/></div>
              <div class="seg-text">
                <div class="seg-icon"><ion-icon name="time"></ion-icon></div>
                <h4><span class="seg-age" data-i18n="segments.5.age">Adulto mayor</span> <span data-i18n="segments.5.title">Prevención y agilidad</span></h4><p data-i18n="segments.5.desc">Pequeños olvidos frecuentes. Buscas mantener tu mente lúcida y activa para no perder independencia.</p>
              </div>
            </article>
          </div>
        </div>
        <div class="segments-dots" aria-hidden="true"></div>
        <button class="segments-arrow next" aria-label="Siguiente">›</button>
      </div>
    </section>    <!-- Sección previa5: Núcleo interactivo Método X -->
    <section class="previa5-v2" id="previa5">
      <style>
        .previa5-v2 {
          position: relative;
          min-height: 100vh;
          overflow: hidden;
          background: #692ac6;
          font-family: 'Gilroy-Regular', sans-serif;
          cursor: none;
        }

        .previa5-v2 * { box-sizing: border-box; }
        .previa5-v2.pv5-paused * { animation-play-state: paused !important; }
        @media (min-width: 981px) { .previa5-v2 { cursor: none; } }

        .previa5-v2 .noise-overlay {
          position: absolute;
          inset: 0;
          pointer-events: none;
          z-index: 2;
          opacity: 0.03;
          background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        .previa5-v2 #canvas-container {
          position: absolute;
          inset: 0;
          z-index: 1;
        }

        .previa5-v2 #neural-canvas {
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
        }

        .previa5-v2 .ui-layer {
          position: relative;
          min-height: 100vh;
          z-index: 3;
        }

        .previa5-v2 .title-header {
          position: absolute;
          top: 22px;
          left: 0;
          width: 100%;
          transform: none;
          text-align: center;
          z-index: 30;
          opacity: 0;
        }

        .previa5-v2 .pv5-label {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          padding: 6px 12px;
          border-radius: 999px;
          border: 1px solid rgba(94, 180, 185, 0.5);
          background: rgba(255, 255, 255, 0.1);
          backdrop-filter: blur(6px);
          margin-bottom: 4px;
        }

        .previa5-v2 .pv5-label-dot {
          width: 7px;
          height: 7px;
          border-radius: 50%;
          background: #5eb4b9;
          box-shadow: 0 0 10px rgba(94, 180, 185, 0.9);
        }

        .previa5-v2 .pv5-label-text {
          font-size: 11px;
          color: rgba(228, 252, 255, 0.95);
          letter-spacing: .08em;
          text-transform: uppercase;
          font-family: 'Gilroy-Regular', sans-serif;
        }

        .previa5-v2 .title-header h1 {
          font-family: 'Gilroy-Bold', sans-serif;
          font-size: clamp(22px, 3.2vw, 34px);
          font-weight: 900;
          color: #ffffff;
          letter-spacing: .18em;
          line-height: 1.02;
          text-transform: uppercase;
          margin: 0 0 1px 0;
          text-shadow: 0 0 40px rgba(94, 180, 185, 0.8);
        }

        .previa5-v2 .title-header p {
          font-size: 13px;
          color: rgba(223, 252, 255, 0.9);
          letter-spacing: .1em;
          line-height: 1.05;
          text-transform: uppercase;
          margin: 0;
        }

        .previa5-v2 .pv5-title-underline {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
          margin-top: 4px;
        }

        .previa5-v2 .pv5-title-underline span {
          display: block;
          height: 3px;
          border-radius: 999px;
          background: linear-gradient(90deg, rgba(255,255,255,.35), rgba(94,180,185,.95), rgba(255,255,255,.35));
          box-shadow: 0 0 14px rgba(94, 180, 185, 0.55);
          animation: pv5LineLoop 2.4s ease-in-out infinite;
        }

        .previa5-v2 .pv5-title-underline .pv5-u-left,
        .previa5-v2 .pv5-title-underline .pv5-u-right { width: 40px; opacity: .6; }
        .previa5-v2 .pv5-title-underline .pv5-u-center { width: 84px; }
        @keyframes pv5LineLoop {
          0%, 100% { opacity: .75; transform: scaleX(1); }
          50% { opacity: 1; transform: scaleX(1.06); }
        }
        .previa5-v2 .glitch-text { position: relative; }
        .previa5-v2 .glitch-text::before,
        .previa5-v2 .glitch-text::after {
          content: attr(data-text);
          position: absolute;
          inset: 0;
          opacity: 0;
          pointer-events: none;
        }
        .previa5-v2.active .glitch-text::before { color: #5eb4b9; transform: translateX(1px); opacity: .4; }
        .previa5-v2.active .glitch-text::after { color: #ffffff; transform: translateX(-1px); opacity: .25; }

        .previa5-v2 .center-brain {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          width: 260px;
          height: 260px;
          cursor: pointer;
          z-index: 15;
        }

        .previa5-v2 .brain-container {
          width: 100%;
          height: 100%;
          position: relative;
          filter: drop-shadow(0 0 60px rgba(138, 43, 226, 0.6));
          transition: filter 0.3s ease;
        }

        .previa5-v2 .center-brain:hover .brain-container {
          filter: drop-shadow(0 0 100px rgba(138, 43, 226, 0.9)) drop-shadow(0 0 150px rgba(0, 255, 255, 0.4));
        }

        .previa5-v2 .brain-image {
          width: 100%;
          height: 100%;
          object-fit: contain;
          animation: breathe 4s ease-in-out infinite, brainToneShift 2.2s ease-in-out infinite;
          filter: contrast(1.18) saturate(1.22) brightness(1.06) hue-rotate(0deg) drop-shadow(0 0 18px rgba(255,255,255,.24));
        }
        .previa5-v2.active .brain-image {
          animation: breathe 4s ease-in-out infinite, brainToneShiftStrong 1.35s ease-in-out infinite;
        }
        @keyframes brainToneShift {
          0%, 100% { filter: contrast(1.1) saturate(1.12) brightness(1.02) hue-rotate(0deg) drop-shadow(0 0 16px rgba(255,255,255,.22)); }
          50% { filter: contrast(1.3) saturate(1.45) brightness(1.1) hue-rotate(24deg) drop-shadow(0 0 28px rgba(94,180,185,.55)); }
        }
        @keyframes brainToneShiftStrong {
          0%, 100% { filter: contrast(1.18) saturate(1.25) brightness(1.05) hue-rotate(0deg) drop-shadow(0 0 22px rgba(255,255,255,.3)); }
          25% { filter: contrast(1.45) saturate(1.7) brightness(1.15) hue-rotate(40deg) drop-shadow(0 0 34px rgba(94,180,185,.75)); }
          50% { filter: contrast(1.55) saturate(1.9) brightness(1.2) hue-rotate(78deg) drop-shadow(0 0 42px rgba(94,180,185,.85)); }
          75% { filter: contrast(1.4) saturate(1.65) brightness(1.12) hue-rotate(-22deg) drop-shadow(0 0 34px rgba(105,42,198,.8)); }
        }
        .previa5-v2 .brain-svg {
          position: absolute;
          inset: 0;
          width: 100%;
          height: 100%;
          pointer-events: none;
        }
        @keyframes breathe { 0%,100% { transform: scale(1) translateY(0); } 50% { transform: scale(1.03) translateY(-8px); } }

        @keyframes drawBrain { to { stroke-dashoffset: 0; } }
        @keyframes pulseBrain { 0%,100% { stroke-opacity: 0.55; filter: brightness(1); } 50% { stroke-opacity: 1; filter: brightness(1.2); } }

        .previa5-v2 .circuit-lines { position: absolute; inset: 0; opacity: 0; }
        .previa5-v2.active .circuit-lines { opacity: 1; }
        .previa5-v2 .circuit-line { stroke: #5eb4b9; stroke-width: 1.5; fill: none; stroke-dasharray: 20 10; animation: flowCircuit 2s linear infinite; opacity: 0.9; }
        @keyframes flowCircuit { to { stroke-dashoffset: -30; } }

        .previa5-v2 .pulse-text {
          position: absolute;
          bottom: -54px;
          left: 50%;
          transform: translateX(-50%);
          font-family: 'Gilroy-Bold', sans-serif;
          font-size: 16px;
          font-weight: 700;
          color: #00ffff;
          letter-spacing: 6px;
          text-transform: uppercase;
          opacity: 0;
          text-shadow: 0 0 14px rgba(94, 180, 185, 0.9);
        }

        .previa5-v2 .typing-cursor { display:inline-block; width:3px; height:18px; background:#00ffff; margin-left:5px; animation:blink 1s infinite; }
        @keyframes blink { 0%,50% { opacity: 1; } 51%,100% { opacity: 0; } }

        .previa5-v2 .pilar {
          position: absolute;
          width: 260px;
          min-height: 320px;
          opacity: 0;
          transform: scale(0);
          cursor: pointer;
          z-index: 10;
        }

        .previa5-v2 .pilar-content {
          width: 100%;
          height: 100%;
          position: relative;
          overflow: hidden;
          background: linear-gradient(160deg, rgba(24, 10, 44, .98) 0%, rgba(56, 20, 102, .98) 44%, rgba(119, 36, 170, .98) 100%);
          backdrop-filter: blur(16px);
          border: 1px solid rgba(255, 255, 255, 0.42);
          border-radius: 34px;
          padding: 170px 22px 24px;
          display: flex;
          flex-direction: column;
          align-items: flex-start;
          justify-content: flex-start;
          box-shadow:
            0 24px 55px rgba(12, 6, 36, 0.5),
            inset 0 0 30px rgba(255, 255, 255, 0.12),
            inset 0 -40px 60px rgba(10, 5, 28, .2);
          transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease;
        }

        .previa5-v2 .pilar-content::before {
          content: "";
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          height: 58%;
          background:
            radial-gradient(circle at 18% 20%, rgba(255,255,255,.26), transparent 34%),
            radial-gradient(circle at 85% 0%, rgba(94,180,185,.34), transparent 40%),
            linear-gradient(135deg, rgba(28, 12, 60, .95), rgba(94,180,185,.28) 50%, rgba(119, 36, 170, .95));
          clip-path: polygon(0 0, 100% 0, 100% 74%, 14% 100%, 0 100%);
          border-radius: 34px 34px 0 0;
          z-index: 0;
        }

        .previa5-v2 .pilar-content::after {
          content: none;
        }

        .previa5-v2 .pilar:hover .pilar-content { transform: translateY(-10px) scale(1.05); border-color: rgba(0,255,255,.88); box-shadow: 0 28px 72px rgba(10, 5, 32, 0.62), inset 0 0 60px rgba(0,255,255,.14); }

        .previa5-v2 .pilar-title {
          font-family: 'Gilroy-Bold', sans-serif;
          font-size: 20px;
          font-weight: 700;
          text-transform: none;
          letter-spacing: .01em;
          color: transparent;
          background: linear-gradient(90deg, #ffffff 0%, #c9faff 35%, #5eb4b9 65%, #ffffff 100%);
          -webkit-background-clip: text;
          background-clip: text;
          text-align: left;
          margin-bottom: 2px;
          position: relative;
          z-index: 2;
          filter: drop-shadow(0 0 10px rgba(94,180,185,.28));
        }

        .previa5-v2 .pilar-subtitle {
          font-size: 13px;
          color: rgba(255,255,255,.86);
          text-align: left;
          letter-spacing: .02em;
          text-transform: none;
          line-height: 1.22;
          margin: 0;
          position: relative;
          z-index: 2;
          max-width: 95%;
        }
        .previa5-v2 .pilar-footer {
          margin-top: auto;
          width: 100%;
          display: flex;
          align-items: center;
          justify-content: flex-start;
          gap: 10px;
          position: relative;
          z-index: 2;
          padding-top: 8px;
        }
        .previa5-v2 .pilar-chip {
          display: inline-flex;
          align-items: center;
          gap: 7px;
          font-size: 11px;
          letter-spacing: .08em;
          text-transform: uppercase;
          color: rgba(221, 255, 255, .95);
          padding: 7px 10px;
          border-radius: 999px;
          border: 1px solid rgba(255,255,255,.28);
          background: rgba(255,255,255,.08);
          backdrop-filter: blur(8px);
          box-shadow: inset 0 0 14px rgba(255,255,255,.08);
        }
        .previa5-v2 .pilar-chip::before {
          content: "";
          width: 7px;
          height: 7px;
          border-radius: 50%;
          background: #5eb4b9;
          box-shadow: 0 0 10px rgba(94,180,185,.95);
          animation: pv5ChipPulse 1.8s ease-in-out infinite;
        }
        .previa5-v2 .pilar-radar {
          position: absolute;
          top: 88px;
          right: 16px;
          width: 54px;
          height: 54px;
          border-radius: 14px;
          border: 1px solid rgba(94,180,185,.48);
          background: linear-gradient(145deg, rgba(255,255,255,.14), rgba(255,255,255,.04));
          backdrop-filter: blur(8px);
          box-shadow: 0 0 0 1px rgba(255,255,255,.14), 0 10px 24px rgba(8, 214, 236, .24);
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 3;
          overflow: visible;
        }
        .previa5-v2 .pilar-radar::before,
        .previa5-v2 .pilar-radar::after {
          content: "";
          position: absolute;
          inset: 0;
          border-radius: 14px;
          border: 1px solid rgba(94,180,185,.6);
          animation: pv5RadarPing 1.7s ease-out infinite;
        }
        .previa5-v2 .pilar-radar::after { animation-delay: .85s; }
        .previa5-v2 .pilar-radar-dot {
          width: 12px;
          height: 12px;
          border-radius: 50%;
          background: #5eb4b9;
          box-shadow: 0 0 14px rgba(94,180,185,.95);
          animation: pv5RadarDot 1.3s ease-in-out infinite;
        }
        .previa5-v2 .pilar-icon {
          width: 118px;
          height: 118px;
          margin-bottom: 0;
          position: absolute;
          left: 22px;
          top: 92px;
          z-index: 2;
          overflow: visible;
          filter: drop-shadow(0 0 20px currentColor);
          animation: pv5IconFloat 3.2s ease-in-out infinite, pv5IconHue 2.4s ease-in-out infinite;
        }
        .previa5-v2 .pilar-icon-img { width: 100%; height: 100%; object-fit: contain; display: block; }
        .previa5-v2 .pilar-icon::before {
          content: "";
          position: absolute;
          left: 50%;
          bottom: -8px;
          width: 2px;
          height: 44px;
          transform: translateX(-50%);
          background: linear-gradient(to top, rgba(0,255,255,.0), rgba(0,255,255,.95), rgba(0,255,255,.0));
          opacity: .95;
          pointer-events: none;
          box-shadow: 0 0 14px rgba(0,255,255,.75);
          animation: pv5LineRise 1.25s linear infinite;
        }
        .previa5-v2 .pilar-icon::after {
          content: "";
          position: absolute;
          left: 0;
          right: 0;
          bottom: 8px;
          width: 2px;
          height: 28px;
          background: linear-gradient(to top, rgba(0,255,255,0), rgba(0,255,255,.82), rgba(0,255,255,0));
          box-shadow: 110px 0 0 0 rgba(0,255,255,.82), 0 0 12px rgba(0,255,255,.65), 110px 0 12px rgba(0,255,255,.65);
          opacity: .9;
          animation: pv5SideRise 1.6s linear infinite;
        }
        @keyframes pv5IconFloat {
          0%,100% { transform: translateY(0); }
          50% { transform: translateY(-6px); }
        }
        @keyframes pv5IconHue {
          0%, 100% { filter: hue-rotate(0deg) saturate(1.1) contrast(1.05) drop-shadow(0 0 16px rgba(94,180,185,.45)); }
          50% { filter: hue-rotate(42deg) saturate(1.55) contrast(1.18) drop-shadow(0 0 26px rgba(94,180,185,.85)); }
        }
        @keyframes pv5IconPulse {
          0%,100% { transform: scale(1); opacity:.7; }
          50% { transform: scale(1.05); opacity:1; }
        }
        @keyframes pv5LineRise {
          0% { transform: translateX(-50%) translateY(14px); opacity: .2; }
          50% { opacity: 1; }
          100% { transform: translateX(-50%) translateY(-22px); opacity: .15; }
        }
        @keyframes pv5SideRise {
          0% { transform: translateY(10px); opacity:.22; }
          50% { opacity:.95; }
          100% { transform: translateY(-16px); opacity:.2; }
        }
        @keyframes pv5ChipPulse {
          0%,100% { transform: scale(1); opacity: .85; }
          50% { transform: scale(1.2); opacity: 1; }
        }
        @keyframes pv5RadarPing {
          0% { transform: scale(1); opacity: .7; }
          100% { transform: scale(1.45); opacity: 0; }
        }
        @keyframes pv5RadarDot {
          0%,100% { transform: scale(1); }
          50% { transform: scale(1.2); }
        }
        @keyframes pv5Shimmer {
          0% { background-position: 0 0, -120% 0; }
          100% { background-position: 0 0, 120% 0; }
        }

        .previa5-v2 .scan-line {
          position:absolute;
          top:-6px;
          left:0;
          width:100%;
          height:4px;
          background: linear-gradient(90deg, transparent, #00ffff, transparent);
          opacity:0;
          box-shadow: 0 0 18px rgba(0, 255, 255, .85);
        }

        .previa5-v2 .connection-line {
          position: absolute;
          height: 2px;
          background: linear-gradient(90deg, #8a2be2, #00ffff);
          transform-origin: left center;
          opacity: 0;
          box-shadow: 0 0 10px currentColor;
          pointer-events: none;
          z-index: 6;
          overflow: visible;
          isolation: isolate;
        }
        .previa5-v2 .connection-line::before {
          content: "";
          position: absolute;
          left: -2px;
          right: -2px;
          top: 50%;
          height: 10px;
          transform: translateY(-50%);
          background: linear-gradient(90deg, rgba(138,43,226,.08), rgba(0,255,255,.45), rgba(138,43,226,.08));
          filter: blur(4px);
          opacity: .7;
          animation: pv5NeuralAura 1.7s ease-in-out infinite;
          z-index: -1;
        }
        .previa5-v2 .connection-line::after {
          content: "";
          position: absolute;
          left: -10%;
          top: 50%;
          width: 18%;
          height: 4px;
          transform: translateY(-50%);
          border-radius: 999px;
          background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.95), rgba(94,180,185,.9), rgba(255,255,255,0));
          box-shadow: 0 0 8px rgba(255,255,255,.7), 0 0 16px rgba(94,180,185,.75);
          animation: pv5NeuralPulse 1.05s linear infinite;
        }
        @keyframes pv5NeuralAura {
          0%, 100% { opacity: .45; filter: blur(4px); }
          50% { opacity: .95; filter: blur(6px); }
        }
        @keyframes pv5NeuralPulse {
          0% { left: -12%; opacity: 0; }
          12% { opacity: .95; }
          88% { opacity: .95; }
          100% { left: 100%; opacity: 0; }
        }
        .previa5-v2 .energy-ring {
          position: absolute;
          border: 2px solid rgba(0,255,255,.5);
          border-radius: 50%;
          pointer-events: none;
          opacity: 0;
          z-index: 8;
        }
        .previa5-v2 .cursor {
          position: absolute;
          width: 18px;
          height: 18px;
          border: 2px solid #00ffff;
          border-radius: 50%;
          pointer-events: none;
          z-index: 50;
          transform: translate(-50%, -50%);
          mix-blend-mode: screen;
        }
        .previa5-v2 .cursor-trail {
          position: absolute;
          width: 36px;
          height: 36px;
          border: 1px solid rgba(138,43,226,.5);
          border-radius: 50%;
          pointer-events: none;
          z-index: 49;
          transform: translate(-50%, -50%);
        }
        .previa5-v2 .beam {
          position: absolute;
          width: 3px;
          height: 0;
          background: linear-gradient(to bottom, #5eb4b9, #ffffff);
          box-shadow: 0 0 16px rgba(94, 180, 185, .8);
          pointer-events: none;
          z-index: 7;
        }

        .previa5-v2 .wave-container { position:absolute; bottom:16px; left:50%; transform:translateX(-50%); width:120px; height:36px; opacity:0; }
        .previa5-v2 .wave-bar { position:absolute; bottom:0; width:4px; background:linear-gradient(to top, #6d33c7, #5eb4b9); border-radius:2px; animation:wave 1s ease-in-out infinite; }
        @keyframes wave { 0%,100% { height:10%; } 50% { height:100%; } }

        .previa5-v2 .eye-pupil { animation: eyeScan 3s ease-in-out infinite; }
        @keyframes eyeScan { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-10px); } 75% { transform: translateX(10px); } }

        @media (max-width: 980px) {
          .previa5-v2 { min-height: calc(100vh + 2rem); padding: 42px 14px 20px; padding-bottom: 2rem; }
          .previa5-v2 .ui-layer {
            min-height: auto;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            align-items: start;
          }
          .previa5-v2 .title-header { position: static; transform:none; opacity:1 !important; margin-top: -6px; }
          .previa5-v2 .pv5-label { margin-bottom: 3px; }
          .previa5-v2 .pv5-label-text { font-size: 10px; }
          .previa5-v2 .title-header h1 { line-height: .96; margin-bottom: 0; }
          .previa5-v2 .title-header p { line-height: 1; }
          .previa5-v2 .pv5-title-underline { margin-top: 3px; }
          .previa5-v2 .pv5-title-underline .pv5-u-left,
          .previa5-v2 .pv5-title-underline .pv5-u-right { width: 30px; }
          .previa5-v2 .pv5-title-underline .pv5-u-center { width: 62px; }
          .previa5-v2 .title-header,
          .previa5-v2 .center-brain,
          .previa5-v2 .pulse-text { grid-column: 1 / -1; }
          .previa5-v2 .center-brain { position: relative; top:auto; left:auto; transform:none; width:180px; height:180px; margin: 8px auto 12px; justify-self: center; }
          .previa5-v2 .pulse-text { position: static; transform:none; text-align:center; opacity:1; margin-top:8px; letter-spacing:4px; }
          .previa5-v2 .pulse-text { margin-bottom: 2rem; }
          .previa5-v2 .pilar { position:relative !important; top:auto !important; left:auto !important; right:auto !important; bottom:auto !important; transform:none !important; width:100%; min-height:196px; display:none; }
          .previa5-v2 .pilar-radar { width: 44px; height: 44px; top: 78px; right: 10px; border-radius: 12px; }
          .previa5-v2 .pilar-radar::before,
          .previa5-v2 .pilar-radar::after { border-radius: 12px; }
          .previa5-v2 .pilar-footer { padding-top: 10px; }
          .previa5-v2 .pilar-chip { font-size: 10px; padding: 6px 8px; }
          .previa5-v2.active .pilar { display:block; }
          .previa5-v2 #canvas-container { opacity:.35; }
          .previa5-v2 .cursor,
          .previa5-v2 .cursor-trail { display:none; }
        }
      </style>

      <div class="noise-overlay"></div>
      <div class="cursor" id="pv5Cursor"></div>
      <div class="cursor-trail" id="pv5CursorTrail"></div>
      <div id="canvas-container"><canvas id="neural-canvas"></canvas></div>

      <div class="ui-layer">
        <div class="title-header" id="titleHeader">
          <div class="pv5-label">
            <span class="pv5-label-dot"></span>
            <span class="pv5-label-text" data-i18n="previa5.kicker">Sistema Cognitivo Neural</span>
          </div>
          <h1 class="glitch-text" data-text="EL MÉTODO X" data-i18n="previa5.title">EL MÉTODO X</h1>
          <p data-i18n="previa5.subtitle">Los 4 Pilares del Sistema Neural</p>
          <div class="pv5-title-underline" aria-hidden="true">
            <span class="pv5-u-left"></span>
            <span class="pv5-u-center"></span>
            <span class="pv5-u-right"></span>
          </div>
        </div>

        <div class="center-brain" id="centerBrain">
          <div class="brain-container">
            <img class="brain-image" src="./assets/images/2b.png" alt="Núcleo cognitivo IQeXponencial" />
            <svg class="brain-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
              <g class="circuit-lines"><path class="circuit-line" d="M100 30 L100 10" /><path class="circuit-line" d="M150 80 L170 70" /><path class="circuit-line" d="M160 150 L175 165" /><path class="circuit-line" d="M40 150 L25 165" /><path class="circuit-line" d="M50 80 L30 70" /></g>
            </svg>
          </div>
          <div class="pulse-text" id="pulseText"><span id="typingText" data-i18n="previa5.pulse">PULSAR</span><span class="typing-cursor"></span></div>
        </div>

        <div class="pilar" id="pilar1" style="top: 8%; left: 16%; transform: none;">
          <div class="pilar-content">
            <div class="scan-line"></div>
            <div class="pilar-icon">
              <img class="pilar-icon-img" src="https://iqexponencial.app/api/images/b52e3334-da6c-4714-8d11-10ed67d8f2d7" alt="Icono Decodificación" />
            </div>
            <div class="pilar-radar" aria-hidden="true"><span class="pilar-radar-dot"></span></div>
            <h3 class="pilar-title" data-i18n="previa5.card1.title">Decodificación</h3>
            <p class="pilar-subtitle" data-i18n="previa5.card1.subtitle">Análisis de Input</p>
            <div class="pilar-footer">
              <span class="pilar-chip" data-i18n="previa5.cardStatus">Activo</span>
            </div>
          </div>
        </div>
        <div class="pilar" id="pilar2" style="top: 8%; right: 16%; transform: none;">
          <div class="pilar-content">
            <div class="scan-line"></div>
            <div class="pilar-icon">
              <img class="pilar-icon-img" src="./assets/images/neuro.png" alt="Icono Arquitectura" />
            </div>
            <div class="pilar-radar" aria-hidden="true"><span class="pilar-radar-dot"></span></div>
            <h3 class="pilar-title" data-i18n="previa5.card2.title">Arquitectura</h3>
            <p class="pilar-subtitle" data-i18n="previa5.card2.subtitle">Procesamiento Estructural</p>
            <div class="pilar-footer">
              <span class="pilar-chip" data-i18n="previa5.cardStatus">Activo</span>
            </div>
          </div>
        </div>
        <div class="pilar" id="pilar3" style="bottom: 8%; right: 16%; transform: none;">
          <div class="pilar-content">
            <div class="scan-line"></div>
            <div class="pilar-icon">
              <img class="pilar-icon-img" src="./assets/images/micro2.png" alt="Icono Proyección" />
            </div>
            <div class="pilar-radar" aria-hidden="true"><span class="pilar-radar-dot"></span></div>
            <div class="wave-container" id="waveContainer"><div class="wave-bar" style="left:10px;animation-delay:0s"></div><div class="wave-bar" style="left:20px;animation-delay:.1s"></div><div class="wave-bar" style="left:30px;animation-delay:.2s"></div><div class="wave-bar" style="left:40px;animation-delay:.3s"></div><div class="wave-bar" style="left:50px;animation-delay:.4s"></div><div class="wave-bar" style="left:60px;animation-delay:.5s"></div><div class="wave-bar" style="left:70px;animation-delay:.6s"></div><div class="wave-bar" style="left:80px;animation-delay:.7s"></div><div class="wave-bar" style="left:90px;animation-delay:.8s"></div><div class="wave-bar" style="left:100px;animation-delay:.9s"></div></div>
            <h3 class="pilar-title" data-i18n="previa5.card3.title">Proyección</h3>
            <p class="pilar-subtitle" data-i18n="previa5.card3.subtitle">Output y Comunicación</p>
            <div class="pilar-footer">
              <span class="pilar-chip" data-i18n="previa5.cardStatus">Activo</span>
            </div>
          </div>
        </div>
        <div class="pilar" id="pilar4" style="bottom: 8%; left: 16%; transform: none;">
          <div class="pilar-content">
            <div class="scan-line"></div>
            <div class="pilar-icon">
              <img class="pilar-icon-img" src="./assets/images/1.png" alt="Icono Neuro-Activación" />
            </div>
            <div class="pilar-radar" aria-hidden="true"><span class="pilar-radar-dot"></span></div>
            <h3 class="pilar-title" data-i18n="previa5.card4.title">Neuro-Activación</h3>
            <p class="pilar-subtitle" data-i18n="previa5.card4.subtitle">Potencial y Aceleración</p>
            <div class="pilar-footer">
              <span class="pilar-chip" data-i18n="previa5.cardStatus">Activo</span>
            </div>
          </div>
        </div>
      </div>

      <script>
      (function(){
        if (typeof gsap === 'undefined') return;
        const root = document.getElementById('previa5');
        if(!root) return;
        const canvas = root.querySelector('#neural-canvas');
        const ctx = canvas.getContext('2d');
        let width, height, particles = [], mouse = {x:0,y:0}, isActivated = false;
        const isMobileViewport = window.matchMedia('(max-width: 980px)').matches;
        const frameBudgetMs = isMobileViewport ? (1000 / 30) : (1000 / 60);
        let lastFrameTs = 0;
        let synapseSkipTick = 0;
        const centerBrain = root.querySelector('#centerBrain');
        const pulseText = root.querySelector('#pulseText');
        const typingText = root.querySelector('#typingText');
        const titleHeader = root.querySelector('#titleHeader');
        const cursor = root.querySelector('#pv5Cursor');
        const cursorTrail = root.querySelector('#pv5CursorTrail');
        const isDesktop = window.matchMedia('(min-width: 981px)').matches;

        // Always start collapsed until user clicks the center.
        root.classList.remove('active');
        root.querySelectorAll('.connection-line').forEach((line)=>line.remove());
        gsap.set(root.querySelectorAll('.pilar'), { opacity: 0, scale: 0, y: 0 });

        function resize(){ const r = root.getBoundingClientRect(); width = canvas.width = r.width; height = canvas.height = Math.max(r.height, 640); }
        window.addEventListener('resize', resize); resize();

        function Particle(x,y,type='ambient'){ this.x=x||Math.random()*width; this.y=y||Math.random()*height; this.vx=(Math.random()-.5)*.5; this.vy=(Math.random()-.5)*.5; this.r=Math.random()*2+1; this.t=type; this.p=Math.random()*Math.PI*2; this.e=Math.random(); }
        Particle.prototype.update=function(){ this.x+=this.vx; this.y+=this.vy; const dx=mouse.x-this.x, dy=mouse.y-this.y, d=Math.hypot(dx,dy)||1; if(d<90){const f=(90-d)/90; this.vx-=(dx/d)*f*.3; this.vy-=(dy/d)*f*.3;} this.vx*=.99; this.vy*=.99; this.p+=.05; this.e=.5+Math.sin(this.p)*.5; };
        Particle.prototype.draw=function(){ const a=this.t==='brain'?this.e:.34; const color=`rgba(0,255,255,${this.t==='brain'?a:(a*.5)})`; ctx.beginPath(); ctx.arc(this.x,this.y,this.r,0,Math.PI*2); ctx.fillStyle=color; ctx.fill(); if(this.t==='brain'){ ctx.shadowBlur=12; ctx.shadowColor=color; ctx.fill(); ctx.shadowBlur=0; } };

        function initParticles(){
          particles=[];
          const brainCount = isMobileViewport ? 36 : 70;
          const ambientCount = isMobileViewport ? 16 : 42;
          const brainRadius = isMobileViewport ? 150 : 180;
          for(let i=0;i<brainCount;i++){
            const ang=Math.random()*Math.PI*2, dist=Math.random()*brainRadius;
            particles.push(new Particle(width/2+Math.cos(ang)*dist,height/2+Math.sin(ang)*dist,'brain'));
          }
          for(let i=0;i<ambientCount;i++) particles.push(new Particle());
        }
        function drawSynapses(){
          if (isMobileViewport) {
            synapseSkipTick = (synapseSkipTick + 1) % 2;
            if (synapseSkipTick !== 0) return;
          }
          const b=particles.filter(p=>p.t==='brain');
          for(let i=0;i<b.length;i++){
            for(let j=i+1;j<b.length;j++){
              const dx=b[i].x-b[j].x, dy=b[i].y-b[j].y, d=Math.hypot(dx,dy);
              if(d<90){
                const a=(1-d/90)*.55*b[i].e;
                ctx.beginPath();
                ctx.moveTo(b[i].x,b[i].y);
                ctx.lineTo(b[j].x,b[j].y);
                ctx.strokeStyle=`rgba(0,255,255,${a})`;
                ctx.lineWidth=1;
                ctx.stroke();
              }
            }
          }
        }
        function drawField(){ const t=Date.now()*.001; const g=ctx.createRadialGradient(width/2,height/2,0,width/2,height/2,380); g.addColorStop(0,`rgba(0,255,255,${0.09+Math.sin(t)*0.03})`); g.addColorStop(.5,`rgba(94,180,185,${0.07+Math.sin(t*1.3)*0.02})`); g.addColorStop(1,'rgba(0,0,0,0)'); ctx.fillStyle=g; ctx.fillRect(0,0,width,height); }
        let rafId = null;
        let isInViewport = false;
        let hasBootedViewportFx = false;
        let hasBootedHeavyFx = !isMobileViewport;
        function animate(now = 0){
          if(!isInViewport){ rafId = null; return; }
          if (now - lastFrameTs < frameBudgetMs) {
            rafId = requestAnimationFrame(animate);
            return;
          }
          lastFrameTs = now;
          ctx.fillStyle='rgba(105,42,198,0.14)';
          ctx.fillRect(0,0,width,height);
          drawField();
          particles.forEach(p=>{p.update(); p.draw();});
          if(!isActivated) drawSynapses();
          rafId = requestAnimationFrame(animate);
        }

        root.addEventListener('mousemove',(e)=>{
          const r = canvas.getBoundingClientRect();
          mouse.x=e.clientX-r.left; mouse.y=e.clientY-r.top;
          if (!isDesktop || !cursor || !cursorTrail) return;
          gsap.to(cursor, { x: mouse.x, y: mouse.y, duration: .08, overwrite: true });
          gsap.to(cursorTrail, { x: mouse.x, y: mouse.y, duration: .22, overwrite: true });
        });

        function typeText(el,text,s=120){ let i=0; el.textContent=''; (function t(){ if(i<text.length){ el.textContent+=text.charAt(i++); setTimeout(t,s); }})(); }
        function getPulseLabel(){
          const qLang = new URLSearchParams(window.location.search).get('lang');
          const lang = String(qLang || localStorage.getItem('iqx_lang') || document.documentElement.lang || '').toLowerCase();
          if (lang.startsWith('en')) return 'PRESS';
          if (lang.startsWith('pt')) return 'PRESSIONAR';
          return 'PULSAR';
        }

        function drawConnections(){
          const b=centerBrain.getBoundingClientRect();
          const bx=b.left+b.width/2, by=b.top+b.height/2;
          ['pilar1','pilar2','pilar3','pilar4'].forEach((id,idx)=>{
            const p=root.querySelector('#'+id);
            const r=p.getBoundingClientRect();
            const x=r.left+r.width/2, y=r.top+r.height/2;
            const line=document.createElement('div');
            line.className='connection-line';
            const len=Math.hypot(x-bx,y-by);
            const ang=Math.atan2(y-by,x-bx)*180/Math.PI;
            line.style.width='0px';
            line.style.left=(bx-root.getBoundingClientRect().left)+'px';
            line.style.top=(by-root.getBoundingClientRect().top)+'px';
            line.style.transform='rotate('+ang+'deg)';
            root.querySelector('.ui-layer').appendChild(line);
            gsap.to(line,{width:len,opacity:.72,duration:.45,delay:idx*.12,ease:'power2.out'});
          });
        }

        function activateSystem(){
          if(isActivated) return;
          isActivated = true;
          root.classList.add('active');
          const tl = gsap.timeline();
          particles.forEach(p=>{ if(p.t==='brain'){ gsap.to(p,{x:width/2,y:height/2,duration:.8,ease:'power2.in'}); }});
          tl.to(root.querySelector('.brain-container'),{scale:1.15,filter:'drop-shadow(0 0 120px rgba(94,180,185,.8)) brightness(1.3)',duration:.4})
            .to(root.querySelector('.center-brain'),{width:120,height:120,duration:.7,ease:'power3.inOut'},'-=.2');
          gsap.to(pulseText,{opacity:0,duration:.3});
          ['pilar1','pilar2','pilar3','pilar4'].forEach((id,i)=>{
            const el=root.querySelector('#'+id);
            gsap.to(el,{opacity:1,scale:1,duration:.6,delay:.7+i*.12,ease:'back.out(1.7)'});
            gsap.to(el,{y:'+=12',duration:2+i*.22,repeat:-1,yoyo:true,ease:'sine.inOut',delay:1+i*.12});
            gsap.fromTo(el.querySelector('.scan-line'), { opacity: 0, top: 0 }, { opacity: 1, top: '100%', duration: 1, repeat: -1, delay: 1 + i * .1, ease: 'none' });
          });
          for (let i = 0; i < 3; i++) {
            const ring = document.createElement('div');
            ring.className = 'energy-ring';
            ring.style.left = '50%';
            ring.style.top = '50%';
            ring.style.width = '90px';
            ring.style.height = '90px';
            ring.style.transform = 'translate(-50%, -50%)';
            root.appendChild(ring);
            gsap.to(ring, { width: 760, height: 760, opacity: 0, duration: 1.4, delay: i * .2, ease: 'power2.out', onStart: ()=> gsap.set(ring,{opacity:.7}), onComplete: ()=> ring.remove() });
          }
          ['45deg','135deg','225deg','315deg'].forEach((deg, i) => {
            const beam = document.createElement('div');
            beam.className = 'beam';
            beam.style.left = '50%';
            beam.style.top = '50%';
            beam.style.transform = `translate(-50%,-50%) rotate(${deg})`;
            root.appendChild(beam);
            gsap.to(beam, { height: 300, duration: .35, delay: .55 + i * .08, ease: 'power2.out', onComplete: ()=> gsap.to(beam, { opacity: 0, duration: .25, onComplete: ()=> beam.remove() }) });
          });
          setTimeout(drawConnections,1300);
          gsap.to(root.querySelector('#waveContainer'),{opacity:1,duration:.5,delay:1.5});
        }

        function resetSystem(){
          if(!isActivated) return;
          isActivated = false;
          if (isDesktop) {
            root.classList.remove('active');
          } else {
            setTimeout(() => root.classList.remove('active'), 360);
          }
          ['pilar1','pilar2','pilar3','pilar4'].forEach((id)=>{
            const el = root.querySelector('#'+id);
            gsap.killTweensOf(el);
            gsap.killTweensOf(el.querySelector('.scan-line'));
            gsap.to(el,{opacity:0,scale:0,y:0,duration:.35,ease:'power2.inOut'});
          });
          root.querySelectorAll('.connection-line').forEach((line)=>line.remove());
          gsap.killTweensOf(root.querySelector('#waveContainer'));
          gsap.to(root.querySelector('#waveContainer'),{opacity:0,duration:.2});
          gsap.to(root.querySelector('.center-brain'),{width:isDesktop ? 260 : 190,height:isDesktop ? 260 : 190,duration:.5,ease:'power3.out'});
          gsap.to(root.querySelector('.brain-container'),{scale:1,filter:'drop-shadow(0 0 40px rgba(94, 180, 185, 0.42))',duration:.4});
          gsap.to(pulseText,{opacity:1,duration:.3});
          typingText.textContent = getPulseLabel();
          initParticles();
        }

        centerBrain.addEventListener('click', ()=>{
          if (typeof playCardClickSound === 'function') playCardClickSound();
          if (!hasBootedHeavyFx) {
            hasBootedHeavyFx = true;
            initParticles();
          }
          isActivated ? resetSystem() : activateSystem();
        });
        root.querySelectorAll('.pilar').forEach((pilar)=>{
          pilar.addEventListener('click', ()=>{
            if (!isActivated || isDesktop) return;
            if (typeof playCardClickSound === 'function') playCardClickSound();
            const scan = pilar.querySelector('.scan-line');
            gsap.killTweensOf(pilar);
            if (scan) gsap.killTweensOf(scan);
            gsap.to(pilar, { scale: 1.08, duration: .12, ease: 'power2.out' });
            gsap.to(pilar, { scale: .9, duration: .14, delay: .12, ease: 'power2.in' });
            gsap.to(pilar, { opacity: 0, scale: 0, y: 0, duration: .24, delay: .22, ease: 'power2.inOut' });
          });
          pilar.addEventListener('mouseenter', ()=>{
            if(!isActivated || !isDesktop) return;
            root.querySelectorAll('.pilar').forEach((other)=>{ if(other!==pilar){ gsap.to(other,{opacity:.42,duration:.25}); }});
            gsap.to(pilar.querySelector('.pilar-content'), { boxShadow:'0 28px 74px rgba(9,5,28,.64), inset 0 0 44px rgba(94,180,185,.24)', duration:.22, overwrite:true });
            gsap.fromTo(pilar.querySelector('.scan-line'), {opacity:0, top:'-6px'}, {opacity:1, top:'100%', duration:.52, ease:'power2.out'});
          });
          pilar.addEventListener('mouseleave', ()=>{
            if(!isDesktop) return;
            root.querySelectorAll('.pilar').forEach((other)=> gsap.to(other,{opacity:1,duration:.25}));
            gsap.to(pilar.querySelector('.pilar-content'), { boxShadow:'0 16px 44px rgba(9, 5, 28, 0.36), inset 0 0 28px rgba(94, 180, 185, 0.07)', duration:.25, overwrite:true });
          });
        });
        centerBrain.addEventListener('mousemove', (e)=>{
          if (!isDesktop) return;
          const rect = centerBrain.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          gsap.to(root.querySelector('.brain-container'), { x: x * .16, y: y * .16, duration: .25 });
        });
        centerBrain.addEventListener('mouseleave', ()=>{
          gsap.to(root.querySelector('.brain-container'), { x: 0, y: 0, duration: .4, ease: 'power2.out' });
        });

        // Icon micro-animations (loop)
        const loopTweens = [
          gsap.to('#pilar1 .pilar-icon ellipse', { scaleX: 1.08, transformOrigin: '50% 50%', repeat: -1, yoyo: true, duration: 1.8, ease: 'sine.inOut' }),
          gsap.to('#pilar1 .eye-pupil', { x: 6, repeat: -1, yoyo: true, duration: 1.5, ease: 'sine.inOut' }),
          gsap.to('#pilar2 .pilar-icon .blueprint-line', { strokeDashoffset: 0, repeat: -1, duration: 2.4, stagger: .12, ease: 'none' }),
          gsap.to('#pilar2 .pilar-icon', { rotate: 2.5, repeat: -1, yoyo: true, duration: 2.2, ease: 'sine.inOut' }),
          gsap.to('#pilar3 .pilar-icon', { scale: 1.08, repeat: -1, yoyo: true, duration: 1.1, ease: 'sine.inOut' }),
          gsap.to('#pilar3 .pilar-icon line', { opacity: .45, repeat: -1, yoyo: true, duration: .8, stagger: .08, ease: 'sine.inOut' }),
          gsap.to('#pilar4 .pilar-icon circle', { scale: 1.08, transformOrigin: '50% 50%', repeat: -1, yoyo: true, duration: 1.9, stagger: .06, ease: 'sine.inOut' }),
          gsap.to('#pilar4 .pilar-icon', { rotate: -3, repeat: -1, yoyo: true, duration: 2.4, ease: 'sine.inOut' })
        ];
        function setLoopsPaused(paused){
          loopTweens.forEach((t)=>{ if(t) t.paused(paused); });
        }
        function bootViewportFx(){
          if (hasBootedViewportFx) return;
          hasBootedViewportFx = true;
          setTimeout(()=>{ gsap.to(pulseText,{opacity:1,duration:1}); typeText(typingText,getPulseLabel(),150); },900);
          const pv5Label = titleHeader ? titleHeader.querySelector('.pv5-label') : null;
          const pv5Title = titleHeader ? titleHeader.querySelector('.glitch-text') : null;
          const pv5Subtitle = titleHeader ? titleHeader.querySelector('p') : null;
          const pv5Underline = titleHeader ? titleHeader.querySelector('.pv5-title-underline') : null;

          if (titleHeader) gsap.set(titleHeader, { opacity: 1 });

          if (pv5Label) {
            gsap.fromTo(
              pv5Label,
              { x: -280, opacity: 0 },
              { x: 0, opacity: 1, duration: 1.05, delay: .22, ease: 'power3.out' }
            );
          }
          if (pv5Title) {
            gsap.fromTo(
              pv5Title,
              { x: 360, opacity: 0 },
              { x: 0, opacity: 1, duration: 1.18, delay: .3, ease: 'power4.out' }
            );
          }
          if (pv5Subtitle) {
            gsap.fromTo(
              pv5Subtitle,
              { x: 240, y: 60, opacity: 0 },
              { x: 0, y: 0, opacity: 1, duration: 1.08, delay: .4, ease: 'power3.out' }
            );
          }
          if (pv5Underline) {
            gsap.fromTo(
              pv5Underline,
              { y: 180, scaleX: 0.6, opacity: 0, transformOrigin: '50% 50%' },
              { y: 0, scaleX: 1, opacity: 1, duration: 1.12, delay: .48, ease: 'power3.out' }
            );
          }
        }
        function setViewportActive(active){
          if (active) {
            bootViewportFx();
            root.classList.remove('pv5-paused');
            setLoopsPaused(false);
            if (!isInViewport) {
              isInViewport = true;
              if (!rafId) animate();
            }
          } else {
            root.classList.add('pv5-paused');
            setLoopsPaused(true);
            isInViewport = false;
            if (rafId) {
              cancelAnimationFrame(rafId);
              rafId = null;
            }
          }
        }

        if (hasBootedHeavyFx) initParticles();
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              setViewportActive(entry.isIntersecting && entry.intersectionRatio > 0.08);
            });
          }, { threshold: [0, 0.08, 0.2], rootMargin: '120px 0px' });
          observer.observe(root);
        } else {
          setViewportActive(true);
        }
      })();
      </script>
    </section>

    <section class="sec5-new" id="sec5-new">
        <div class="sec5-container">
            <!-- Capas de imagen -->
            <img src="./assets/images/2pro.jpg" alt="Fondo familiar" class="sec5-image sec5-image-back" loading="lazy" decoding="async">
            <img src="./assets/images/1pro.png" alt="Familia" class="sec5-image sec5-image-front" loading="lazy" decoding="async">
            
            <!-- Texto final -->
            <div class="text-panel" id="textPanel">
                <h2 id="line1" data-i18n="sec5.finalTop">UNA SOLUCION</h2>
                <h1 id="line2"></h1>
                <p id="line3" data-i18n-html="sec5.finalBottom">para cada<br>miembro de<br>la familia</p>
            </div>
        </div>

        <style>
            /* Section 5: Nueva versión interactiva */
            .sec5-new {
                position: relative;
                width: 100%;
                max-width: 100%;
                height: 100vh;
                max-height: 900px;
                overflow: hidden;
                background: #fff;
                margin: 0 auto;
            }

            .sec5-container {
                position: relative;
                width: 100%;
                height: 100%;
            }

            /* Capas de imagen */
            .sec5-image {
                position: absolute;
                width: 100%;
                height: 100%;
                object-fit: cover;
                will-change: transform, opacity;
            }

            .sec5-image-back {
                z-index: 0;
                opacity: 0;
                transform: translateX(80px);
                transition: opacity 0.85s ease 0.45s, transform 1s cubic-bezier(0.22, 1, 0.36, 1) 0.45s;
            }

            .sec5-image-front {
                z-index: 1;
                transform: translateY(100%);
                transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1);
            }

            .sec5-new.revealed .sec5-image-front {
                transform: translateY(0);
            }

            .sec5-new.revealed .sec5-image-back {
                opacity: 1;
                transform: translateX(0);
            }

            /* Las 3 columnas */
            .columns {
                position: absolute;
                inset: 0;
                display: flex;
                z-index: 10;
            }

            .column {
                flex: 1;
                background: #5eb4b9;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 20px;
                transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
                border-right: 1px solid #333;
                position: relative;
                overflow: hidden;
                cursor: pointer;
            }

            .column:last-child {
                border-right: none;
            }

            .column.revealed {
                opacity: 0;
                pointer-events: none;
                transform: scale(1.1);
            }

            /* Icono de dedo pulsante */
            .touch-icon {
                width: 80px;
                height: 80px;
                background: linear-gradient(135deg, #692ac6 0%, #8a5ad9 100%);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                animation: touchPulse 1.5s ease infinite;
                box-shadow: 0 0 0 0 rgba(105, 42, 198, 0.7);
                cursor: pointer;
                transition: transform 0.2s ease;
            }

            .touch-icon ion-icon {
                font-size: 40px;
                color: white;
                --ionicon-stroke-width: 32px;
            }

            @keyframes touchPulse {
                0% {
                    transform: scale(1);
                    box-shadow: 0 0 0 0 rgba(105, 42, 198, 0.7);
                }
                70% {
                    transform: scale(1.05);
                    box-shadow: 0 0 0 20px rgba(105, 42, 198, 0);
                }
                100% {
                    transform: scale(1);
                    box-shadow: 0 0 0 0 rgba(105, 42, 198, 0);
                }
            }

            .column:active .touch-icon {
                transform: scale(0.9);
                animation: none;
            }

            /* Texto de accion */
            .call-text {
                color: #fff;
                font-size: 13px;
                text-align: center;
                padding: 0 10px;
                line-height: 1.4;
                font-weight: 500;
            }

            /* Responsive */
            @media (max-width: 900px) {
                .sec5-new {
                    min-height: 480px;
                    max-height: 600px;
                }
                
                .touch-icon {
                    width: 70px;
                    height: 70px;
                }
                
                .touch-icon ion-icon {
                    font-size: 32px;
                }
                
                .text-panel h1 {
                    font-size: 36px;
                }
                
                .call-text {
                    color: #fff !important;
                    font-size: 14px !important;
                    text-shadow: 0 2px 8px rgba(0,0,0,0.8) !important;
                    position: relative;
                    z-index: 100 !important;
                    text-align: center !important;
                }
            }

            @media (max-width: 480px) {
                .sec5-new {
                    min-height: 400px;
                }
                
                .touch-icon {
                    width: 60px;
                    height: 60px;
                }
                
                .touch-icon ion-icon {
                    font-size: 28px;
                }
                
                .text-panel h1 {
                    font-size: 28px;
                }
                
                .call-counter {
                    top: 20px;
                    padding: 10px 18px;
                    font-size: 12px;
                }
                
                .instruction {
                    bottom: 40px;
                    font-size: 11px;
                    color: #fff !important;
                    text-shadow: 0 2px 8px rgba(0,0,0,0.8) !important;
                    z-index: 100 !important;
                }
            }

            /* Ripple effect al tocar */
            .ripple {
                position: absolute;
                border-radius: 50%;
                background: rgba(105, 42, 198, 0.3);
                transform: scale(0);
                animation: rippleEffect 0.6s ease-out;
                pointer-events: none;
            }

            @keyframes rippleEffect {
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }

            /* Contador */
            .call-counter {
                position: absolute;
                top: 40px;
                left: 50%;
                transform: translateX(-50%);
                background: rgba(0, 0, 0, 0.8);
                padding: 12px 24px;
                border-radius: 30px;
                color: #fff;
                font-size: 14px;
                z-index: 20;
                border: 1px solid #333;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .call-counter .dot {
                width: 8px;
                height: 8px;
                background: #333;
                border-radius: 50%;
                transition: all 0.3s ease;
            }

            .call-counter .dot.active {
                background: #692ac6;
                box-shadow: 0 0 10px #692ac6;
            }

            /* Panel de texto final */
            .text-panel {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                text-align: center;
                opacity: 0;
                pointer-events: none;
                z-index: 100;
                width: 90%;
                transition: opacity 0.8s ease;
            }

            .text-panel.revealed {
                opacity: 1;
                pointer-events: all;
            }

            .text-panel h2 {
                color: rgba(255, 255, 255, 0.9);
                font-size: 14px;
                text-transform: uppercase;
                letter-spacing: 4px;
                margin-bottom: 20px;
                opacity: 0;
                transform: translateY(20px);
                text-shadow: 0 2px 10px rgba(0,0,0,0.5);
            }

            .text-panel h1 {
                font-size: 48px;
                font-weight: 900;
                margin-bottom: 20px;
                line-height: 1.1;
                text-shadow: 0 4px 20px rgba(0,0,0,0.8);
            }

            .text-panel h1 .letter {
                display: inline-block;
                color: #fff;
                opacity: 0;
                transform: translateY(30px);
            }

            .text-panel h1 .letter.x {
                color: #c77dff;
                animation: spinX 3s ease-in-out infinite;
            }

            .text-panel h1 .letter.o {
                color: #ffd700;
                animation: pulseO 2s ease-in-out infinite;
            }

            .text-panel p {
                color: rgba(255, 255, 255, 0.95);
                font-size: 18px;
                line-height: 1.5;
                opacity: 0;
                transform: translateX(-40px);
                text-shadow: 0 2px 10px rgba(0,0,0,0.5);
            }

            @keyframes spinX {
                0%, 100% { transform: rotate(0deg); }
                50% { transform: rotate(360deg); }
            }

            @keyframes pulseO {
                0%, 100% { transform: scale(1); }
                50% { transform: scale(1.2); }
            }

            /* Efecto flash al tocar */
            .touch-flash {
                position: absolute;
                inset: 0;
                background: radial-gradient(circle, rgba(105, 42, 198, 0.4) 0%, transparent 70%);
                opacity: 0;
                pointer-events: none;
                z-index: 15;
            }

            .touch-flash.active {
                animation: flashTouch 0.6s ease-out;
            }

            @keyframes flashTouch {
                0% { opacity: 0; transform: scale(0.8); }
                50% { opacity: 1; transform: scale(1.2); }
                100% { opacity: 0; transform: scale(1.5); }
            }

            /* Instructional inicial */
            .instruction {
                position: absolute;
                bottom: 60px;
                left: 50%;
                transform: translateX(-50%);
                color: #666;
                font-size: 13px;
                text-align: center;
                z-index: 20;
                animation: fadeInstruction 3s ease infinite;
                white-space: nowrap;
            }

            @keyframes fadeInstruction {
                0%, 100% { opacity: 0.4; }
                50% { opacity: 0.8; }
            }

            .instruction.hidden {
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            /* Responsive tweaks */
            @media (max-width: 380px) {
                .touch-icon {
                    width: 70px;
                    height: 70px;
                }
                .text-panel h1 {
                    font-size: 42px;
                }
            }
        </style>

        <script>
            (function initSec5Experience() {
                const container = document.getElementById('sec5-new');
                const textPanel = document.getElementById('textPanel');
                const line2 = document.getElementById('line2');
                if (!container || !textPanel || !line2) return;
                
                const word = 'eXponencial';
                let finalRevealed = false;
                let textAnimated = false;

                function revealFinal() {
                    if (finalRevealed) return;
                    finalRevealed = true;
                    
                    // Revelar imagen completa
                    container.classList.add('revealed');
                    
                    // Mostrar texto
                    setTimeout(() => {
                        textPanel.classList.add('revealed');
                        animateText();
                    }, 600);
                }

                function animateText() {
                    if (textAnimated) return;
                    textAnimated = true;

                    const line1 = document.getElementById('line1');
                    const line3 = document.getElementById('line3');
                    line2.innerHTML = '';
                    
                    // Linea 1
                    setTimeout(() => {
                        line1.style.transition = 'all 0.6s ease';
                        line1.style.opacity = '1';
                        line1.style.transform = 'translateY(0)';
                    }, 200);
                    
                    // Letras de eXponencial
                    let delay = 600;
                    word.split('').forEach((char, index) => {
                        setTimeout(() => {
                            const span = document.createElement('span');
                            span.className = 'letter';
                            span.textContent = char;
                            
                            if (char.toLowerCase() === 'x') span.classList.add('x');
                            else if (char.toLowerCase() === 'o') span.classList.add('o');
                            
                            span.style.transition = 'all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
                            
                            line2.appendChild(span);
                            
                            requestAnimationFrame(() => {
                                span.style.opacity = '1';
                                span.style.transform = 'translateY(0)';
                            });
                        }, delay + (index * 100));
                    });
                    
                    // Linea 3
                    setTimeout(() => {
                        line3.style.transition = 'all 0.75s cubic-bezier(0.22, 1, 0.36, 1)';
                        line3.style.opacity = '1';
                        line3.style.transform = 'translateX(0)';
                    }, delay + word.length * 100 + 300);
                }

                if ('IntersectionObserver' in window) {
                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting && entry.intersectionRatio > 0.35) {
                                revealFinal();
                                observer.disconnect();
                            }
                        });
                    }, { threshold: [0.2, 0.35, 0.6] });
                    observer.observe(container);
                } else {
                    revealFinal();
                }
            })();
        </script>
    </section>

