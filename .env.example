# LearnHouse self-hosted config for iqexponencial.com
# Copy to your platform secrets (Railway variables). Do not commit real secrets.

# Required core services
LEARNHOUSE_SQL_CONNECTION_STRING=postgresql://user:password@host:5432/database
LEARNHOUSE_REDIS_CONNECTION_STRING=redis://default:password@host:6379/0

# Collab service can reuse the same Redis. If omitted, start.sh maps it automatically.
LEARNHOUSE_REDIS_URL=redis://default:password@host:6379/0

# Security secrets (generate strong random values)
LEARNHOUSE_AUTH_JWT_SECRET_KEY=replace_with_64_plus_random_chars
COLLAB_INTERNAL_KEY=replace_with_64_plus_random_chars

# Domain and platform
LEARNHOUSE_DOMAIN=iqexponencial.com
LEARNHOUSE_FRONTEND_DOMAIN=iqexponencial.com
LEARNHOUSE_ALLOWED_ORIGINS=https://iqexponencial.com
LEARNHOUSE_COOKIE_DOMAIN=.iqexponencial.com
LEARNHOUSE_SSL=true

# Initial admin bootstrap
LEARNHOUSE_INITIAL_ADMIN_EMAIL=admin@iqexponencial.com
LEARNHOUSE_INITIAL_ADMIN_PASSWORD=ChangeThisPasswordNow123!

# Public runtime URLs used by the web app
NEXT_PUBLIC_LEARNHOUSE_BACKEND_URL=https://iqexponencial.com/
NEXT_PUBLIC_LEARNHOUSE_API_URL=https://iqexponencial.com/api/v1/
NEXT_PUBLIC_LEARNHOUSE_DOMAIN=iqexponencial.com
NEXT_PUBLIC_LEARNHOUSE_TOP_DOMAIN=iqexponencial.com
NEXT_PUBLIC_LEARNHOUSE_HTTPS=true
NEXT_PUBLIC_COLLAB_URL=wss://iqexponencial.com/collab

# Optional Jitsi live sessions
# Public fallback (no JaaS): leave only LEARNHOUSE_JITSI_PUBLIC_DOMAIN or omit both.
LEARNHOUSE_JITSI_PUBLIC_DOMAIN=meet.jit.si
# JaaS managed setup: set all three values below to enable JWT-backed rooms inside the LMS.
# LEARNHOUSE_JITSI_DOMAIN=8x8.vc
# LEARNHOUSE_JITSI_APP_ID=your_jaas_app_id
# LEARNHOUSE_JITSI_KID=your_jaas_key_id
# LEARNHOUSE_JITSI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Internal ports inside the container (usually keep defaults)
LEARNHOUSE_WEB_INTERNAL_PORT=8000
LEARNHOUSE_PORT=9000
COLLAB_PORT=4000
